        async function createGroup() {
            const groupName = document.getElementById("groupNameInput").value.trim();
            const selectedMembers = Array.from(document.querySelectorAll(".group-member-checkbox:checked")).map(cb => parseInt(cb.value));

            if (!groupName) { alert("Vui lòng nhập tên nhóm"); return; }
            if (selectedMembers.length < 2) { alert("Vui lòng chọn ít nhất 2 thành viên"); return; }

            try {
                const res = await fetch("/Chat/CreateGroup", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ GroupName: groupName, MemberIds: selectedMembers })
                });
                const data = await res.json();
                if (data.success) {
                    closeCreateGroupModal();
                    // Reload page to show new group (simple way)
                    window.location.reload();
                } else {
                    alert(data.message || "Tạo nhóm thất bại");
                }
            } catch (err) {
                console.error("Create Group Error:", err);
                alert("Lỗi khi tạo nhóm");
            }
        }
