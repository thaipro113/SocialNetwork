        function triggerFile() { document.getElementById("fileInput").click(); }
        
        async function uploadAndSendFile(file) {
             if (!file || !currentConversationId) return;
             
             // Check size/type if needed
             const form = new FormData();
             form.append("conversationId", currentConversationId);
             form.append("file", file);
             
             try {
                 const res = await fetch('/Chat/UploadAttachment', { method: 'POST', body: form, credentials: 'include' });
                 const d = await res.json();
                 if (!d.success) { alert(d.message || 'Tải file thất bại'); return; }
                 
                 // Gửi qua SignalR
                 await chatConnection.invoke("SendMessage", parseInt(currentConversationId), d.content);
             } catch (err) {
                 console.error('UploadAttachment Error', err);
                 alert("Lỗi khi tải lên file/ảnh");
             }
        }

        
        function showPreview(file) {
             if (!file) return;
             // Only preview images
             if (file.type.startsWith("image/")) {
                 const reader = new FileReader();
                 reader.onload = (e) => {
                     document.getElementById("previewImage").src = e.target.result;
                     document.getElementById("previewContainer").classList.remove("hidden");
                 };
                 reader.readAsDataURL(file);
                 pendingFile = file;
             } else {
                 // For non-images, just auto-send (or maybe add a file icon preview? for now auto-send behavior was nice)
                 // But request said "copy image".
                 // If file select, let's keep auto-send for files, or unify?
                 // Let's unify for consistency.
                 // But for non-image, we can't 'preview' effectively with an img tag.
                 // Let's just auto-send non-images for now, or alert name.
                 // To stick to "image" request:
                 uploadAndSendFile(file);
             }
        }

        async function handleFileSelected(e) {
            const file = e.target.files[0];
            showPreview(file);
        }

        // Paste Image Handler
        document.getElementById('messageInput').addEventListener('paste', function(e) {
            const items = (e.clipboardData || e.originalEvent.clipboardData).items;
            let file = null;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf('image') !== -1) {
                    file = items[i].getAsFile();
                    break;
                }
            }
            if (file) {
                e.preventDefault();
                showPreview(file);
            }
        });
