            menu.classList.toggle('hidden');
        }
        // === Ẩn tin nhắn (xóa cho tôi) & Thu hồi (xóa cho mọi người)
        function storageKey() { return `hiddenMsgs:${myId}`; }
        function getHiddenMessageSet() {
            try { const arr = JSON.parse(localStorage.getItem(storageKey()) || "[]"); return new Set(arr); } catch { return new Set(); }
        }
        function saveHiddenMessageSet(set) { localStorage.setItem(storageKey(), JSON.stringify(Array.from(set))); }
        // === Tìm kiếm cuộc trò chuyện ===
        (function bindConversationSearch() {
            const wrapper = document.querySelector('.col-span-4');
            const input = wrapper ? wrapper.querySelector('input[type="text"]') : null;
            if (!input) return;
            input.addEventListener('input', () => {
                const q = input.value.toLowerCase().trim();
                document.querySelectorAll('#conversationList .conv-item').forEach(item => {
                    const name = (item.dataset.username || '').toLowerCase();
                    const msgEl = item.querySelector('[id^="msg-"]');
                    const last = (msgEl ? msgEl.textContent : '').toLowerCase();
                    const show = name.includes(q) || last.includes(q);
                    item.style.display = show ? '' : 'none';
                });
            });
        })();
     
        function updateLocalLastMessageAfterDelete() {
            const visibleMessages = Array.from(document.querySelectorAll('#messages [data-msgid]'))
                .map(el => {
                    const mid = el.dataset.msgid;
                    const content = el.querySelector('.break-words')?.innerHTML || '';
                    const time = el.querySelector('div.mt-1')?.textContent || '';
                    const isMine = el.closest('.flex')?.classList.contains('justify-end');
                    return { mid: parseInt(mid), content, time, isMine };
                })
                .filter(m => m.mid && !isNaN(m.mid));
            if (visibleMessages.length === 0) {
                const msgEl = document.getElementById(`msg-${currentConversationId}`);
                const timeEl = document.getElementById(`time-${currentConversationId}`);
                if (msgEl) msgEl.innerHTML = "Không có tin nhắn";
                if (timeEl) timeEl.textContent = "";
                return;
            }
            // Lấy tin cuối cùng hiển thị
            const lastVisible = visibleMessages[visibleMessages.length - 1];
            const msgEl = document.getElementById(`msg-${currentConversationId}`);
            const timeEl = document.getElementById(`time-${currentConversationId}`);
            if (msgEl) {
                msgEl.innerHTML = lastVisible.isMine
                    ? `<strong>Bạn:</strong> ${lastVisible.content}`
                    : lastVisible.content;
            }
            if (timeEl) timeEl.textContent = lastVisible.time;
        }
    
 
        // Xử lý khi bấm nút "Hủy"
        document.getElementById("cancelDelete").addEventListener("click", () => {
            document.getElementById("confirmationModal").classList.add("hidden");
            pendingDeleteId = null;
        });
        // Xử lý khi bấm nút "Xóa"
        document.getElementById("confirmDelete").addEventListener("click", async () => {
            if (!pendingDeleteId) return;
            const res = await fetch("/Chat/DeleteConversation", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: "include",
                body: JSON.stringify(parseInt(pendingDeleteId))
            });
            const d = await res.json();
            if (d.success) {
                const el = document.querySelector(`.conv-item[data-convid='${pendingDeleteId}']`);
                if (el) el.remove();
                if (currentConversationId == pendingDeleteId) {
                    document.getElementById("messages").innerHTML = "";
                    currentConversationId = null;
                }
            } else {
                alert(d.message);
            }
            document.getElementById("confirmationModal").classList.add("hidden");
            pendingDeleteId = null;
        });

        // Xử lý khi bấm nút "Hủy" rời nhóm
        document.getElementById("cancelLeaveGroupBtn").addEventListener("click", () => {
            document.getElementById("leaveGroupModal").classList.add("hidden");
        });

        // Xử lý khi bấm nút "Rời nhóm"
        document.getElementById("confirmLeaveGroupBtn").addEventListener("click", () => {
            if (currentConversationId) {
                leaveGroup(currentConversationId);
            }
            document.getElementById("leaveGroupModal").classList.add("hidden");
        });


        document.getElementById("cancelDisbandGroupBtn").addEventListener("click", () => {
            document.getElementById("disbandGroupModal").classList.add("hidden");
        });

        document.getElementById("confirmDisbandGroupBtn").addEventListener("click", async () => {
            if (!currentConversationId) return;
            
            try {
                const res = await fetch("/Chat/DisbandGroup", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(parseInt(currentConversationId))
                });
                const d = await res.json();

                if (d.success) {
                    // UI update handled by GroupDeleted event, but we also do it manually for the admin to be sure
                    const el = document.querySelector(`.conv-item[data-convid='${currentConversationId}']`);
                    if (el) el.remove();

                    document.getElementById("messages").innerHTML = "";
                    document.getElementById("chatWith").querySelector('.flex.items-center.gap-3').innerHTML = '<span class="text-lg font-semibold text-gray-500 dark:text-gray-300">Nhóm đã giải tán</span>';
                    currentConversationId = null;
                    updateVideoCallButton();
                    document.getElementById("leaveGroupBtn").classList.add("hidden");
                    document.getElementById("disbandGroupBtn").classList.add("hidden");
                } else {
                    alert(d.message || "Không thể giải tán nhóm");
                }
            } catch (err) {
                alert("Lỗi kết nối");
            }
            document.getElementById("disbandGroupModal").classList.add("hidden");
        });

        // === Group Info Functions ===
        function closeGroupInfo() {
            document.getElementById("groupInfoModal").classList.add("hidden");
        }

        // === Group Chat Functions ===
         function closeCallRejectedModal() {
            document.getElementById("callRejectedModal").classList.add("hidden");
            cleanupCall();
        }
        function closeCallEndedModal() {
            document.getElementById("callEndedModal").classList.add("hidden");
            cleanupCall();
        }

        // Tìm kiếm realtime cho tạo nhóm
        document.getElementById("memberSearchInput")?.addEventListener("input", function () {
            const query = this.value.toLowerCase().trim();
            document.querySelectorAll("#memberList label").forEach(label => {
                const name = label.querySelector("span").textContent.toLowerCase();
                label.style.display = name.includes(query) ? "flex" : "none";
            });
        });

        // === NEW CHAT MODAL FUNCTIONS ===
        function openNewChatModal() {
            document.getElementById("newChatModal").classList.remove("hidden");
            document.getElementById("newChatSearchInput").value = "";
            // Reset hiển thị tất cả bạn bè
            document.querySelectorAll("#newChatFriendList .friend-item").forEach(item => {
                item.style.display = "flex";
            });
        }

        function closeNewChatModal() {
            document.getElementById("newChatModal").classList.add("hidden");
        }

        async function startChatWithFriend(userId, userName) {
            closeNewChatModal();
            // Kiểm tra xem đã có cuộc trò chuyện với người này chưa
            const existingConv = document.querySelector(`.conv-item[data-otherid='${userId}']`);
            if (existingConv) {
                // Đã có → mở luôn
                const convId = existingConv.dataset.convid;
                const isGroup = existingConv.dataset.isgroup === 'true';
                const adminId = existingConv.dataset.adminid;
                await openConversation(convId, userId, userName, isGroup, adminId);
            } else {
                // Chưa có → tạo mới
                await startChat(userId);
            }
        }

        // Tìm kiếm realtime cho tin nhắn mới
        document.getElementById("newChatSearchInput")?.addEventListener("input", function () {
            const query = this.value.toLowerCase().trim();
            document.querySelectorAll("#newChatFriendList .friend-item").forEach(item => {
                const name = item.dataset.username.toLowerCase();
                item.style.display = name.includes(query) ? "flex" : "none";
            });
        });

        // Tìm kiếm cuộc trò chuyện
        document.getElementById("conversationSearchInput")?.addEventListener("input", function () {
            const query = this.value.toLowerCase().trim();
            document.querySelectorAll("#conversationList .conv-item").forEach(item => {
                const name = (item.dataset.username || '').toLowerCase();
                const msgEl = item.querySelector('[id^="msg-"]');
                const last = (msgEl ? msgEl.textContent : '').toLowerCase();
                const show = name.includes(query) || last.includes(query);
                item.style.display = show ? '' : 'none';
            });
        });
    </script>
    <script src="~/js/videoCall.js"></script>
}

