@{
    ViewData["Title"] = "Nhắn tin";
    Layout = "~/Views/Shared/_ChatLayout.cshtml";
    var friends = ViewBag.Friends as List<SocialNetwork.Models.User>;
    var convs = ViewBag.Conversations as List<dynamic>;
    int? myId = ViewBag.MyUserId;
}
<div class="h-[calc(100dvh-4rem)] sm:h-[calc(100vh-8rem)] flex flex-col bg-gray-50 dark:bg-gray-900">
    <!-- Main Chat Container -->
    <div class="flex-1 flex overflow-hidden">
        <!-- Left Sidebar - Conversations List -->
        <div id="chatSidebar" class="w-full md:w-80 bg-white dark:bg-gray-800 border-r dark:border-gray-700 flex md:flex flex-col">
            <!-- Sidebar Header -->
            <div class="p-4 border-b dark:border-gray-700">
                <div class="flex justify-between items-center mb-3">
                    <h2 class="text-xl font-bold text-gray-800 dark:text-white">Đoạn chat</h2>
                    <div class="flex gap-2">
                        <button onclick="openNewChatModal()" class="w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 flex items-center justify-center transition" title="Tin nhắn mới">
                            <i class="fa-solid fa-pen-to-square text-gray-600 dark:text-gray-300"></i>
                        </button>
                        <button onclick="openCreateGroupModal()" class="w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 flex items-center justify-center transition" title="Tạo nhóm chat">
                            <i class="fa-solid fa-user-group text-gray-600 dark:text-gray-300"></i>
                        </button>
                    </div>
                </div>
                <div class="relative">
                    <input type="text" id="conversationSearchInput" placeholder="Tìm kiếm cuộc trò chuyện..." class="w-full rounded-full border border-gray-200 dark:border-gray-600 pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-gray-700 dark:text-white dark:placeholder-gray-400" />
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-2 text-gray-400 text-sm"></i>
                </div>  
            </div>
            <!-- Conversations List -->
            <div id="conversationList" class="flex-1 overflow-y-auto overflow-x-hidden">
            @foreach (var c in convs)
            {
                var isGroup = c.IsGroup;
                var user = !isGroup ? friends.FirstOrDefault(f => f.UserId == c.OtherUserId) : null;
                var name = isGroup ? c.GroupName : user?.FullName;
                var avatar = isGroup 
                    ? (string.IsNullOrEmpty(c.GroupAvatar) ? Url.Content("~/Uploads/default-group.png") : Url.Content($"~/Uploads/{c.GroupAvatar}"))
                    : (user?.ImageUrl != null ? Url.Content($"~/Uploads/{user.ImageUrl}") : Url.Content("~/Uploads/default-avatar.png"));
                
                <div class="conv-item group flex items-center gap-3 p-3 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition border-b dark:border-gray-700"
                     data-convid="@c.Id"
                     data-otherid="@c.OtherUserId"
                     data-username="@name"
                     data-isgroup="@isGroup.ToString().ToLower()"
                     data-adminid="@c.GroupAdminId"
                     onclick="handleConversationClick('@c.Id', '@c.OtherUserId', '@name', @isGroup.ToString().ToLower(), '@c.GroupAdminId')">
                    <div class="relative flex-shrink-0">
                        @if (!isGroup) {
                             <img src="@avatar" class="w-14 h-14 rounded-full object-cover" />
                        } else {
                            <img src="@avatar" class="w-14 h-14 rounded-full object-cover" />
                        }

                        @if (!isGroup) {
                            var onlineUserIds = ViewBag.OnlineUserIds as IEnumerable<int> ?? new List<int>();
                            var isOnline = user != null && onlineUserIds.Contains(user.UserId);
                            <span id="online-status-@user.UserId" class="absolute bottom-0 right-0 block w-3.5 h-3.5 rounded-full bg-green-500 ring-2 ring-white" style="display: @(isOnline ? "block" : "none")"></span>
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between mb-1">
                            <h3 class="font-semibold text-sm text-gray-800 dark:text-gray-200 truncate @(c.UnreadCount > 0 ? "font-extrabold text-gray-900 dark:text-white" : "")">@name</h3>
                            <span class="text-[11px] text-gray-400 flex-shrink-0" id="time-@c.Id">
                                @{
                                    string timeStr = "";
                                    if (c.LastMessage != null)
                                    {
                                        var lastMsgTime = ((DateTime)c.LastMessage.CreatedAt);
                                        var diff = DateTime.Now - lastMsgTime;
                                        
                                        if (diff.TotalDays < 1)
                                        {
                                            timeStr = lastMsgTime.ToString("HH:mm");
                                        }
                                        else if (diff.TotalDays < 7)
                                        {
                                            timeStr = $"{(int)diff.TotalDays} ngày";
                                        }
                                        else if (diff.TotalDays < 30)
                                        {
                                            timeStr = $"{(int)(diff.TotalDays / 7)} tuần";
                                        }
                                        else if (diff.TotalDays < 365)
                                        {
                                            timeStr = $"{(int)(diff.TotalDays / 30)} tháng";
                                        }
                                        else
                                        {
                                            timeStr = $"{(int)(diff.TotalDays / 365)} năm";
                                        }
                                    }
                                }
                                @timeStr
                            </span>
                        </div>
                        <div class="flex items-center justify-between">
                            <p class="text-xs text-gray-500 dark:text-gray-400 truncate flex-1 @(c.UnreadCount > 0 ? "font-bold text-gray-900 dark:text-white" : "")" id="msg-@c.Id">
                                @if (c.LastMessage != null)
                                {
                                    var content = c.LastMessage.Content ?? "";
                                    var displayText = "";

                                    if (content.StartsWith("[system]") && content.EndsWith("[/system]"))
                                    {
                                        // Tin nhắn hệ thống - chỉ hiển thị nội dung bên trong
                                        displayText = content.Replace("[system]", "").Replace("[/system]", "");
                                    }
                                    else if (content.StartsWith("[img]") && content.EndsWith("[/img]"))
                                    {
                                        displayText = "đã gửi 1 ảnh";
                                    }
                                    else if (content.StartsWith("[video]") && content.EndsWith("[/video]"))
                                    {
                                        displayText = "đã gửi 1 video";
                                    }
                                    else if (content.StartsWith("[file]") && content.Contains("[/file]"))
                                    {
                                        // Lấy tên file từ [file]Tên file.ext|url[/file]
                                        var parts = content.Split('|');
                                        if (parts.Length > 0)
                                        {
                                            var namePart = parts[0].Substring(6); // bỏ [file]
                                            displayText = "đã gửi 1 tệp";
                                        }
                                        else
                                        {
                                            displayText = "đã gửi 1 tệp";
                                        }
                                    }
                                    else
                                    {
                                        displayText = content.Length > 50 ? content.Substring(0, 47) + "..." : content;
                                    }

                                    // Không thêm "Bạn:" cho tin nhắn hệ thống
                                    if (content.StartsWith("[system]"))
                                    {
                                        <text>@displayText</text>
                                    }
                                    else if (c.LastMessage.SenderId == myId)
                                    {
                                        <text><strong>Bạn:</strong> @displayText</text>
                                    }
                                    else
                                    {
                                        <text>@displayText</text>
                                    }
                                }
                                else
                                {
                                    <text>Không có tin nhắn</text>
                                }
                            </p>
                            <span id="unread-@c.Id" class="bg-blue-600 text-white text-[10px] font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1 flex-shrink-0 @(c.UnreadCount > 0 ? "" : "hidden")">
                                @(c.UnreadCount > 99 ? "99+" : c.UnreadCount)
                            </span>
                        </div>
                    </div>
                    <button onclick="deleteConversation(event, '@c.Id')" class="opacity-0 group-hover:opacity-100 text-gray-400 hover:text-red-500 transition absolute right-3 top-1/2 -translate-y-1/2" title="Xóa đoạn chat">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            }
            </div>
        </div>

        <!-- Right Side - Chat Area -->
        <div id="chatMain" class="hidden md:flex flex-1 bg-white dark:bg-gray-800 flex-col">
            <!-- Chat Header -->
            <div class="h-16 px-4 md:px-6 border-b dark:border-gray-700 flex items-center justify-between bg-white dark:bg-gray-800" id="chatHeader">
                <div id="chatWith" class="flex items-center justify-between w-full">
                    <div class="flex items-center gap-3">
                        <button onclick="backToList()" class="md:hidden text-gray-600 dark:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-full transition">
                            <i class="fa-solid fa-arrow-left text-lg"></i>
                        </button>
                        <span class="text-base md:text-lg font-semibold text-gray-500 dark:text-gray-300">Chọn một cuộc trò chuyện để bắt đầu</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <button id="groupInfoBtn" class="hidden w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition" onclick="showGroupInfo()" title="Thông tin nhóm">
                            <i class="fa-solid fa-circle-info text-gray-600 dark:text-gray-300"></i>
                        </button>
                        <button id="audioCallBtn" class="hidden w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition" onclick="safeInitiateVideoCall(currentConversationId, currentOtherUserId, currentIsGroup, true)" title="Gọi thoại">
                            <i class="fa-solid fa-phone text-gray-600 dark:text-gray-300"></i>
                        </button>
                        <button id="videoCallBtn" class="hidden w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition" onclick="safeInitiateVideoCall(currentConversationId, currentOtherUserId, currentIsGroup, false)" title="Gọi video">
                            <i class="fa-solid fa-video text-gray-600 dark:text-gray-300"></i>
                        </button>
                        <button id="leaveGroupBtn" class="hidden w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition" onclick="confirmLeaveGroup()" title="Rời nhóm">
                            <i class="fa-solid fa-right-from-bracket text-red-500"></i>
                        </button>
                        <button id="disbandGroupBtn" class="hidden w-10 h-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition" onclick="confirmDisbandGroup()" title="Giải tán nhóm">
                            <i class="fa-solid fa-trash text-red-600"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Messages Area -->
            <div id="messages" class="flex-1 overflow-y-auto px-6 py-4 bg-gray-50 dark:bg-gray-900 space-y-3"></div>

            <!-- Image Preview Container -->
            <div id="previewContainer" class="hidden px-4 py-2 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700">
                <div class="relative inline-block">
                    <img id="previewImage" class="h-20 rounded-lg border border-gray-300 dark:border-gray-600" />
                    <button type="button" onclick="clearPreview()" class="absolute -top-2 -right-2 w-5 h-5 bg-gray-500 rounded-full text-white flex items-center justify-center hover:bg-gray-600 shadow-sm transition">
                        <i class="fa-solid fa-xmark text-xs"></i>
                    </button>
                </div>
            </div>

            <!-- Message Input -->
            <form id="sendForm" class="h-14 md:h-16 px-3 md:px-6 border-t dark:border-gray-700 bg-white dark:bg-gray-800 flex items-center gap-2 md:gap-3 relative" onsubmit="sendMessage(event); return false;">
                <button type="button" class="w-8 h-8 md:w-9 md:h-9 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition text-gray-500 dark:text-gray-400" title="Emoji" onclick="toggleEmojiPicker()">
                    <i class="fa-solid fa-face-smile text-sm md:text-lg"></i>
                </button>
                <button type="button" class="w-8 h-8 md:w-9 md:h-9 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition text-gray-500 dark:text-gray-400" title="Đính kèm" onclick="triggerFile()">
                    <i class="fa-solid fa-paperclip text-sm md:text-lg"></i>
                </button>
                <input id="messageInput" class="flex-1 border-0 bg-gray-100 dark:bg-gray-700 rounded-full px-3 md:px-5 py-2 text-sm md:text-base focus:ring-2 focus:ring-blue-500 focus:outline-none dark:text-white dark:placeholder-gray-400" placeholder="Nhập tin nhắn..." />
                <input id="fileInput" type="file" class="hidden" onchange="handleFileSelected(event)" />
                <partial name="_EmojiPicker" />
                <button type="submit" class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-blue-600 hover:bg-blue-700 flex items-center justify-center transition text-white">
                    <i class="fa-solid fa-paper-plane text-sm md:text-base"></i>
                </button>
            </form>
        </div>
    </div>
</div>
    <!-- 🔹 Modal xác nhận xóa -->
    <div id="confirmationModal"
         class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 w-96 text-center shadow-lg">
            <p class="text-lg font-semibold text-gray-800 mb-4">Xác nhận</p>
            <p id="confirmMessage" class="text-gray-600 mb-6">
                Bạn có chắc muốn xóa đoạn nhắn này?
            </p>
            <div class="flex justify-center space-x-4">
                <button id="confirmDelete"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                    Xóa
                </button>
                <button id="cancelDelete"
                        class="px-4 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition">
                    Hủy
                </button>
            </div>
        </div>
    </div>
    <!-- Modal xác nhận giải tán nhóm -->
    <div id="disbandGroupModal"
         class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 w-96 text-center shadow-lg">
            <p class="text-lg font-semibold text-gray-800 mb-4">Giải tán nhóm</p>
            <p class="text-gray-600 mb-6">
                Bạn có chắc muốn giải tán nhóm này? Hành động này không thể hoàn tác và tất cả tin nhắn sẽ bị xóa.
            </p>
            <div class="flex justify-center space-x-4">
                <button id="confirmDisbandGroupBtn"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                    Giải tán
                </button>
                <button id="cancelDisbandGroupBtn"
                        class="px-4 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition">
                    Hủy
                </button>
            </div>
        </div>
    </div>
    <!-- Modal xác nhận rời nhóm -->
    <div id="leaveGroupModal"
         class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 w-96 text-center shadow-lg">
            <p class="text-lg font-semibold text-gray-800 mb-4">Rời nhóm</p>
            <p class="text-gray-600 mb-6">
                Bạn có chắc muốn rời khỏi nhóm này?
            </p>
            <div class="flex justify-center space-x-4">
                <button id="confirmLeaveGroupBtn"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                    Rời nhóm
                </button>
                <button id="cancelLeaveGroupBtn"
                        class="px-4 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition">
                    Hủy
                </button>
            </div>
        </div>
    </div>
    <!-- Modal: Cuộc gọi bị từ chối -->
    <div id="callRejectedModal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-8 text-center max-w-sm animate-bounce-in">
            <div class="text-6xl mb-4">
                <i class="fa-solid fa-phone-slash text-red-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-2">Cuộc gọi bị từ chối</h3>
            <p class="text-gray-600 mb-6">Người dùng không muốn nhận cuộc gọi lúc này.</p>
            <button onclick="closeCallRejectedModal()" class="px-6 py-3 bg-gray-600 text-white rounded-full hover:bg-gray-700 transition">
                Đóng
            </button>
        </div>
    </div>

    <!-- Modal: Cuộc gọi đã kết thúc -->
    <div id="callEndedModal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-8 text-center max-w-sm animate-bounce-in">
            <div class="text-6xl mb-4">
                <i class="fa-solid fa-phone-slash text-orange-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-2">Cuộc gọi đã kết thúc</h3>
            <p class="text-gray-600 mb-6">Cuộc gọi video đã được kết thúc.</p>
            <button onclick="closeCallEndedModal()" class="px-6 py-3 bg-gray-600 text-white rounded-full hover:bg-gray-700 transition">
                Đóng
            </button>
        </div>
    </div>
    <!-- Modal Thông tin nhóm -->
    <div id="groupInfoModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-md mx-4 flex flex-col max-h-[80vh]">
            <div class="p-4 border-b dark:border-gray-700 flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-800 dark:text-white">Thành viên nhóm</h3>
                <button onclick="closeGroupInfo()" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            <div id="groupMemberList" class="p-4 overflow-y-auto flex-1 space-y-3">
                <!-- Members will be loaded here -->
            </div>
        </div>
    </div>
<!-- Modal Tạo nhóm chat -->
<div id="createGroupModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b dark:border-gray-700">
            <div class="flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-800 dark:text-white">Tạo nhóm chat mới</h3>
                <button onclick="closeCreateGroupModal()" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
        </div>

        <div class="p-6 max-h-96 overflow-y-auto">
            <input type="text" id="groupNameInput" placeholder="Nhập tên nhóm..."
                   class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-gray-700 dark:text-white mb-4" />
            <!-- Thanh tìm kiếm thành viên -->
            <div class="relative mb-4">
                <input type="text" id="memberSearchInput" placeholder="Tìm kiếm bạn bè..."
                       class="w-full pl-10 pr-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-gray-700 dark:text-white" />
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-3.5 text-gray-400"></i>
            </div>
            <!-- Danh sách thành viên (sẽ được lọc realtime) -->
            <div id="memberList" class="space-y-2">
                @foreach (var f in friends)
                {
                    <label class="flex items-center space-x-3 p-3 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg cursor-pointer transition group">
                        <input type="checkbox" value="@f.UserId" class="group-member-checkbox w-5 h-5 text-blue-600 rounded focus:ring-blue-500" />
                        <img src="@(string.IsNullOrEmpty(f.ImageUrl) ? Url.Content("~/Uploads/default-avatar.png") : Url.Content($"~/Uploads/" + f.ImageUrl))"
                             class="w-10 h-10 rounded-full object-cover" />
                        <div class="flex-1">
                            <span class="text-gray-800 dark:text-gray-200 font-medium">@f.FullName</span>
                            <p class="text-xs text-gray-500">Nhấn để chọn</p>
                        </div>
                        <i class="fa-solid fa-check text-green-500 opacity-0 group-has-[:checked]:opacity-100 transition"></i>
                    </label>
                }
            </div>
        </div>

        <div class="p-6 border-t dark:border-gray-700 flex justify-end gap-3">
            <button onclick="closeCreateGroupModal()"
                    class="px-6 py-2.5 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition">
                Hủy
            </button>
            <button onclick="createGroup()"
                    class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2">
                <i class="fa-solid fa-users"></i>
                Tạo nhóm
            </button>
        </div>
    </div>
</div>
<!-- Modal Tin nhắn mới -->
<div id="newChatModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b dark:border-gray-700">
            <div class="flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-800 dark:text-white">Tin nhắn mới</h3>
                <button onclick="closeNewChatModal()" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
        </div>

        <div class="p-6 max-h-96 overflow-y-auto">
            <!-- Thanh tìm kiếm bạn bè -->
            <div class="relative mb-4">
                <input type="text" id="newChatSearchInput" placeholder="Tìm kiếm bạn bè..."
                       class="w-full pl-10 pr-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-gray-700 dark:text-white" />
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-3.5 text-gray-400"></i>
            </div>
            <!-- Danh sách bạn bè -->
            <div id="newChatFriendList" class="space-y-2">
                @foreach (var f in friends)
                {
                    <div class="friend-item flex items-center gap-3 p-3 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg cursor-pointer transition"
                         data-userid="@f.UserId"
                         data-username="@f.FullName"
                         onclick="startChatWithFriend(@f.UserId, '@f.FullName')">
                        <img src="@(string.IsNullOrEmpty(f.ImageUrl) ? Url.Content("~/Uploads/default-avatar.png") : Url.Content($"~/Uploads/" + f.ImageUrl))"
                             class="w-12 h-12 rounded-full object-cover" />
                        <div class="flex-1">
                            <div class="font-medium text-gray-800 dark:text-gray-200">@f.FullName</div>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Nhấn để bắt đầu chat</p>
                        </div>
                        <i class="fa-solid fa-comment text-blue-500"></i>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- Video Call Modal -->
<partial name="_VideoCallModal" />
@section Scripts {
    <script>
        // Safe Video Call Function - Kiểm tra hỗ trợ trước khi gọi
        function safeInitiateVideoCall(conversationId, otherUserId, isGroup = false) {
            // Kiểm tra getUserMedia API
            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                alert("Trình duyệt của bạn không hỗ trợ gọi video. Vui lòng sử dụng trình duyệt hiện đại như Chrome, Firefox, Safari hoặc Edge.");
                return;
            }
            
            // Kiểm tra HTTPS hoặc localhost
            const isSecure = location.protocol === 'https:' || 
                            location.hostname === 'localhost' || 
                            location.hostname === '127.0.0.1';
            
            if (!isSecure) {
                alert("Tính năng gọi video chỉ hoạt động trên HTTPS hoặc localhost. Vui lòng truy cập qua HTTPS để sử dụng tính năng này.");
                return;
            }
            
            // Gọi function gốc nếu được hỗ trợ
            if (typeof initiateVideoCall === 'function') {
                initiateVideoCall(conversationId, otherUserId, isGroup);
            } else {
                console.error('initiateVideoCall function not found');
                alert("Lỗi: Không thể khởi tạo cuộc gọi video");
            }
        }

        // ============================================
        // TIME FORMATTING HELPERS
        // ============================================
        function formatDetailTime(dateStr) {
            if (!dateStr) return "";
            const date = new Date(dateStr);
            if (isNaN(date.getTime())) return "";
            
            const now = new Date();
            const isToday = date.getDate() === now.getDate() &&
                            date.getMonth() === now.getMonth() &&
                            date.getFullYear() === now.getFullYear();
            
            if (isToday) {
                return date.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            } else {
                return date.toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            }
        }

        function formatRelativeTime(dateStr) {
            if (!dateStr) return "";
            const date = new Date(dateStr);
            if (isNaN(date.getTime())) return "";
            
            const now = new Date(); 
            const diffMs = now - date; 
            const diffSeconds = Math.floor(diffMs / 1000);
            
            // Logic matching Server Side C#
            // < 1 day (specifically "Today"): HH:mm
            const isToday = date.getDate() === now.getDate() &&
                            date.getMonth() === now.getMonth() &&
                            date.getFullYear() === now.getFullYear();
                            
            if (isToday) {
                 return date.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            }

            const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
            
            if (diffDays < 1) return date.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }); // Fallback for transition
            if (diffDays < 7) return `${diffDays} ngày`;
            if (diffDays < 30) return `${Math.floor(diffDays / 7)} tuần`;
            if (diffDays < 365) return `${Math.floor(diffDays / 30)} tháng`;
            return `${Math.floor(diffDays / 365)} năm`;
        }
        
        const myId = @((myId ?? 0));
        const friends = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(friends));
        
        // LAST ACTIVE LOGIC
        // Convert C# Dictionary to JS Map/Object
        var lastActiveTimes = @Html.Raw(Json.Serialize(ViewBag.LastActiveTimes ?? new {}));
        var onlineUserIds = @Html.Raw(Json.Serialize(ViewBag.OnlineUserIds ?? new List<int>()));

        function calculateLastActive(userId) {
            const id = parseInt(userId);
             // 1. Check Login
            if (onlineUserIds.includes(id)) {
                return '<p class="text-xs text-green-500 font-medium">Đang hoạt động</p>';
            }
            
            // 2. Check Last Active
            var timeStr = lastActiveTimes[id] || lastActiveTimes["" + id];
            
            if (!timeStr) {
                return ''; 
            }

            var lastActive = new Date(timeStr);
            if (isNaN(lastActive.getTime())) return ''; 

            var diff = new Date() - lastActive; // diff in ms
            var minutes = Math.floor(diff / 60000);
            
            if (minutes < 1) return '<p class="text-xs text-gray-400">Vừa mới truy cập</p>';
            if (minutes < 60) return `<p class="text-xs text-gray-400">Hoạt động ${minutes} phút trước</p>`;
            
            var hours = Math.floor(minutes / 60);
            if (hours < 24) return `<p class="text-xs text-gray-400">Hoạt động ${hours} giờ trước</p>`;
            
            var days = Math.floor(hours / 24);
            return `<p class="text-xs text-gray-400">Hoạt động ${days} ngày trước</p>`;
        }
        let currentConversationId = null;
        let currentOtherUserId = null;
        let currentIsGroup = false;
        const messageAudio = new Audio('/sounds/newmessenge.mp3');
        // ============================================
        // 2. SIGNALR CONNECTION SETUP
        // ============================================
        window.chatConnection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();
        const chatConnection = window.chatConnection;
        chatConnection.start().then(() => { 
            const conversationId = '@(ViewBag.SelectedConversationId ?? "0")';
            const otherUserId = '@(ViewBag.OtherUserId ?? "0")';
            const isGroup = @((ViewBag.IsGroup as bool? ?? false).ToString().ToLower());
            
            if (conversationId && conversationId !== "0" && otherUserId && otherUserId !== "0") {
                openConversation(conversationId, otherUserId, null, isGroup);
            } else {
                // Đảm bảo nút ẩn khi không có conversation
                updateVideoCallButton();
            }
            // ✅ Sắp xếp lại danh sách theo thứ tự đã lưu (sau khi load xong)
            restoreConversationOrder();
            // 🟢 SYNC: Lấy danh sách online mới nhất từ server
            chatConnection.invoke("GetOnlineUsers").then((onlineIds) => {
                onlineIds.forEach(id => {
                    const statusEl = document.getElementById(`online-status-${id}`);
                    if (statusEl) statusEl.style.display = "block";
                });
            }).catch(err => console.error("GetOnlineUsers Error: ", err));
        }).catch(err => console.error("SignalR Connection Error: ", err));
        chatConnection.onclose(() => {
            console.log("Connection closed. Reconnecting...");
            chatConnection.start().catch(err => console.error("Reconnection Error: ", err));
        });
        // ============================================
        // 3. SIGNALR EVENT LISTENERS
        // ============================================
        // 3.1 Message Events
        
        // Listen for User Status
        chatConnection.on("UserOnline", function (userId) {
            // Update Array
            if (!onlineUserIds.includes(userId)) {
                onlineUserIds.push(userId);
            }
            // Remove from Last Active (since online)
            delete lastActiveTimes[userId];

            // Update UI (Green dot)
            const dot = document.getElementById(`online-status-${userId}`);
            if (dot) dot.style.display = "block";

            // Update Header if chatting with this user
            if (currentOtherUserId == userId && !currentIsGroup) {
                 const statusDiv = document.querySelector("#chatWith .flex.items-center.gap-3 div");
                 if (statusDiv) {
                     // Find the <p> tag and update it, or add it
                     let p = statusDiv.querySelector("p:not(.text-gray-800)"); // Avoid changing naming if any
                     // Better selector: look for last p
                     const ps = statusDiv.querySelectorAll("p");
                     // Typically usage: h2 is name, last p is status
                     
                     // If we used calculateLastActive logic, it inserts a <p>.
                     // Let's retry simple logic:
                     let statusP = statusDiv.querySelector(".text-green-500, .text-gray-400");
                     
                     if (!statusP) {
                         statusP = document.createElement("p");
                         statusDiv.appendChild(statusP);
                     }
                     statusP.textContent = "Đang hoạt động";
                     statusP.className = "text-xs text-green-500 font-medium";
                 }
            }
        });

        chatConnection.on("UserOffline", function (userId) {
             // Update Array
            onlineUserIds = onlineUserIds.filter(id => id !== userId);
            
            // Set Last Active to NOW
            lastActiveTimes[userId] = new Date().toISOString(); 

            // Update UI (Green dot)
            const dot = document.getElementById(`online-status-${userId}`);
            if (dot) dot.style.display = "none";
            
             // Update Header if chatting with this user
            if (currentOtherUserId == userId && !currentIsGroup) {
                 const statusDiv = document.querySelector("#chatWith .flex.items-center.gap-3 div");
                 if (statusDiv) {
                     let statusP = statusDiv.querySelector(".text-green-500, .text-gray-400");
                     if (!statusP) {
                         statusP = document.createElement("p");
                         statusDiv.appendChild(statusP);
                     }
                     statusP.textContent = "Vừa mới truy cập";
                     statusP.className = "text-xs text-gray-400";
                 }
            }
        });

        // 🟢 REALTIME: Messages Read (Seen Status)
        chatConnection.on("MessagesRead", (data) => {
            // data: { conversationId, readerId, lastReadMessageId }
            if (currentConversationId == data.conversationId) {
                // Update visible messages statuses
                // Change all "Đã gửi" to "Đã xem" for my messages
                const myMessages = document.querySelectorAll('.message-status'); 
                myMessages.forEach(el => {
                    if (el.textContent === "Đã gửi") {
                        el.textContent = "Đã xem";
                    }
                });
            }
        });

        // REALTIME: Nhận tin nhắn từ người khác
       chatConnection.on("ReceiveMessage", (msg) => {
        const convId = msg.conversationId;
        const senderId = msg.senderId;

        // === Tạo mới nếu chưa có cuộc chat ===
        let convEl = document.querySelector(`.conv-item[data-convid='${convId}']`);
        if (!convEl) {
            let name = "";
            let avatar = "";
            let otherId = senderId;
            const isGroup = msg.isGroup || false;
            const groupAdminId = msg.groupAdminId || 0;

            if (isGroup) {
                name = msg.groupName || "Nhóm chat";
                avatar = msg.groupAvatar ? `/Uploads/${msg.groupAvatar}` : `/Uploads/default-group.png`;
                otherId = 0; 
            } else {
                const friend = friends.find(f => f.UserId == senderId);
                if (!friend) return;
                name = friend.FullName;
                avatar = friend.ImageUrl ? `/Uploads/${friend.ImageUrl}` : `/Uploads/default-avatar.png`;
            }

            const newItem = document.createElement("div");
            newItem.className = "conv-item group flex items-center gap-3 p-3 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition border-b dark:border-gray-700";
            newItem.dataset.convid = convId;
            newItem.dataset.otherid = otherId;
            newItem.dataset.username = name;
            newItem.dataset.isgroup = isGroup;
            newItem.dataset.adminid = groupAdminId;
            
            newItem.onclick = () => handleConversationClick(convId, otherId, name, isGroup, groupAdminId);

            newItem.innerHTML = `
                <div class="relative flex-shrink-0">
                    <img src="${avatar}" class="w-14 h-14 rounded-full object-cover" />
                    ${!isGroup ? '<span class="absolute bottom-0 right-0 block w-3.5 h-3.5 rounded-full bg-green-500 ring-2 ring-white"></span>' : ''}
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between mb-1">
                        <h3 class="font-semibold text-sm text-gray-800 dark:text-gray-200 truncate">${name}</h3>
                        <span class="text-[11px] text-gray-400 flex-shrink-0" id="time-${convId}">
                        <span class="text-[11px] text-gray-400 flex-shrink-0" id="time-${convId}">
                            ${formatRelativeTime(msg.createdAt)}
                        </span>
                        </span>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-xs text-gray-500 dark:text-gray-400 truncate flex-1" id="msg-${convId}">${msg.content}</p>
                        <span id="unread-${convId}" class="hidden bg-blue-600 text-white text-[10px] font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1 flex-shrink-0">0</span>
                    </div>
                </div>
                <button onclick="deleteConversation(event, '${convId}')"
                        class="opacity-0 group-hover:opacity-100 text-gray-400 hover:text-red-500 transition absolute right-3 top-1/2 -translate-y-1/2" title="Xóa đoạn chat">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            `;

            document.getElementById("conversationList").prepend(newItem);
            const order = Array.from(document.getElementById("conversationList").children).map(el => el.dataset.convid);
            localStorage.setItem("conversationOrder", JSON.stringify(order));
        }
        // Hàm chuyển đổi content thành text hiển thị đẹp

        // === Cập nhật tin nhắn cuối + thời gian ===
        const lastMsgEl = document.getElementById(`msg-${convId}`);
        const timeEl = document.getElementById(`time-${convId}`);
        const unreadBadge = document.getElementById(`unread-${convId}`);
        const convItem = document.querySelector(`.conv-item[data-convid='${convId}']`);

       if (lastMsgEl) {
    const isMine = senderId == myId;
    const isSystemMsg = msg.content && msg.content.startsWith("[system]");
    lastMsgEl.innerHTML = formatLastMessageContent(msg.content, isMine);
}
        if (timeEl) {
            timeEl.textContent = formatRelativeTime(msg.createdAt);
        }

        // === FIX: Play sound for ALL messages from others, even if chat is open ===
        const isSystemMsg = msg.content && msg.content.startsWith("[system]");
        
        if (senderId != myId && !isSystemMsg) {
             // Play sound always
            messageAudio.currentTime = 0;
            messageAudio.play().catch(e => console.log("Audio play failed:", e));

            // Only update badge/bold if NOT current conversation
            if (convId != currentConversationId) {
                // In đậm tên + tin cuối
                if (convItem) {
                    convItem.querySelector(".font-semibold")?.classList.add("font-extrabold", "text-gray-900", "dark:text-white");
                    convItem.querySelector(".text-xs")?.classList.add("font-bold", "text-gray-900", "dark:text-white");
                }

                // Tăng badge
                let count = (parseInt(unreadBadge.textContent) || 0) + 1;
                unreadBadge.textContent = count > 99 ? "99+" : count;
                unreadBadge.classList.remove("hidden");
            }
        }

        // === Nếu đang mở đúng cuộc chat này → thêm tin + đánh dấu đã đọc ===
        if (convId == currentConversationId) {
            appendMessage(msg, senderId);
            scrollMessages();
            markConversationAsRead(convId); // Đúng chỗ rồi!
        }

        // Đưa lên đầu
        moveConversationToTop(convId);
    });
        // 🗑 Lắng nghe xóa tin nhắn (thu hồi)
        chatConnection.on("MessageDeleted", (p) => {
            const el = document.querySelector(`[data-msgid="${p.messageId}"]`);
            if (el) el.closest('.flex')?.remove();
        });

        // 🟢 REALTIME: Online Status
        chatConnection.on("UserOnline", (userId) => {
            const statusEl = document.getElementById(`online-status-${userId}`);
            if (statusEl) statusEl.style.display = "block";
        });
        chatConnection.on("UserOffline", (userId) => {
            const statusEl = document.getElementById(`online-status-${userId}`);
            if (statusEl) statusEl.style.display = "none";
        });

        // 🔴 GROUP EVENTS
        chatConnection.on("GroupDeleted", (conversationId) => {
            // Xóa khỏi danh sách
            const el = document.querySelector(`.conv-item[data-convid='${conversationId}']`);
            if (el) el.remove();

            // Nếu đang mở chat này -> clear
            if (currentConversationId == conversationId) {
                document.getElementById("messages").innerHTML = "";
                document.getElementById("chatWith").querySelector('.flex.items-center.gap-3').innerHTML = '<span class="text-lg font-semibold text-gray-500 dark:text-gray-300">Cuộc trò chuyện đã bị xóa</span>';
                currentConversationId = null;
                document.getElementById("videoCallBtn").classList.add("hidden");
                document.getElementById("leaveGroupBtn").classList.add("hidden");
            }
            alert("Nhóm chat đã bị giải tán bởi trưởng nhóm.");
        });

        chatConnection.on("UserLeftGroup", (data) => {
            // data: { conversationId, userId, userName, isSelf }
            
            // Nếu là chính mình rời nhóm
            if (data.isSelf) {
                // Xóa conversation khỏi danh sách
                const el = document.querySelector(`.conv-item[data-convid='${data.conversationId}']`);
                if (el) el.remove();

                // Nếu đang mở chat này -> clear và thông báo
                if (currentConversationId == data.conversationId) {
                    document.getElementById("messages").innerHTML = "";
                    document.getElementById("chatWith").querySelector('.flex.items-center.gap-3').innerHTML = '<span class="text-lg font-semibold text-gray-500 dark:text-gray-300">Bạn đã rời khỏi nhóm</span>';
                    currentConversationId = null;
                    document.getElementById("videoCallBtn").classList.add("hidden");
                    document.getElementById("leaveGroupBtn").classList.add("hidden");
                    document.getElementById("groupInfoBtn").classList.add("hidden");
                    document.getElementById("disbandGroupBtn").classList.add("hidden");
                }
            } else {
                // Người khác rời nhóm
                if (currentConversationId == data.conversationId) {
                    // Cập nhật danh sách thành viên nếu đang mở modal
                    const modal = document.getElementById("groupInfoModal");
                    if (modal && !modal.classList.contains("hidden")) {
                        const memberEl = document.getElementById(`member-${data.userId}`);
                        if (memberEl) memberEl.remove();
                    }
                }
            }
        });
        // ============================================
        // 4. CONVERSATION MANAGEMENT
        // ============================================
        async function openConversation(conversationId, otherUserId, name, isGroup, adminId) {
            currentConversationId = conversationId;
            currentOtherUserId = otherUserId;
            currentIsGroup = isGroup;
            currentAdminId = adminId || 0;
            const res = await fetch(`/Chat/GetMessages?conversationId=${conversationId}`);
            const data = await res.json();
            if (!data.success) return;
            const container = document.getElementById("messages");
            container.innerHTML = "";
            const hidden = getHiddenMessageSet();
            data.data.forEach(m => {
                const mid = m.Id || m.id || m.ID;
                if (!hidden.has(mid)) appendMessage(m, m.senderId);
            });

            // Determine Avatar and Name
            let avatar = "/Uploads/default-avatar.png";
            let displayName = name || "Unknown";
            let profileLink = "#";

            if (isGroup) {
                avatar = "/Uploads/default-group.png"; 
                profileLink = "#"; 
            } else {
                const friend = friends.find(f => f.UserId == otherUserId);
                if (friend) {
                    avatar = friend.ImageUrl ? `/Uploads/${friend.ImageUrl}` : `/Uploads/default-avatar.png`;
                    displayName = friend.FullName;
                    profileLink = `/User/Profile/${friend.UserId}`;
                }
            }

            const chatWith = document.getElementById("chatWith");
            // Chỉ cập nhật phần bên trái (div đầu tiên), giữ nguyên nút video call bên phải
            const leftPart = chatWith.querySelector('.flex.items-center.gap-3');
            if (leftPart) {
                leftPart.innerHTML = `
                    <button onclick="backToList()" class="md:hidden text-gray-600 dark:text-gray-300 p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-full transition mr-2">
                        <i class="fa-solid fa-arrow-left text-lg"></i>
                    </button>
                    <a href="${profileLink}" class="flex items-center gap-3 hover:opacity-90 transition-all group">
                        <img src="${avatar}" 
                             class="w-8 h-8 md:w-10 md:h-10 rounded-full object-cover" />
                        <div>
                            <h2 class="text-sm md:text-base font-semibold text-gray-800 dark:text-white">
                                ${displayName}
                            </h2>
                            ${!isGroup ? calculateLastActive(otherUserId) : ''}
                        </div>
                    </a>
                `;
            }
            const convEl = document.querySelector(`.conv-item[data-convid='${conversationId}']`);
            document.querySelectorAll('.conv-item').forEach(i => i.classList.remove("bg-blue-50", "dark:bg-gray-700"));
            if (convEl) convEl.classList.add("bg-blue-50", "dark:bg-gray-700");
            scrollMessages();
            markConversationAsRead(conversationId);
            // ✅ Gọi API đánh dấu tin nhắn đã đọc
            await fetch("/Chat/MarkAsRead", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: "include",
                body: JSON.stringify(parseInt(conversationId))
            }).then(res => res.json())
                .then(data => {
                    if (data.success && data.totalUnread !== undefined) {
                        const messageCount = document.getElementById("message-count");
                        if (messageCount) {
                            messageCount.textContent = data.totalUnread > 99 ? "99+" : data.totalUnread;
                            messageCount.style.display = data.totalUnread > 0 ? "flex" : "none";
                        }
                    }
                });
            // ✅ Cập nhật nút gọi video
            updateVideoCallButton();

            // ✅ Cập nhật nút Thông tin nhóm
            const infoBtn = document.getElementById("groupInfoBtn");
            if (infoBtn) {
                if (isGroup) infoBtn.classList.remove("hidden");
                else infoBtn.classList.add("hidden");
            }

            // ✅ Cập nhật nút Rời nhóm
            const leaveBtn = document.getElementById("leaveGroupBtn");
            if (leaveBtn) {
                // Hiển thị nút rời nhóm nếu là group
                if (isGroup) {
                    leaveBtn.classList.remove("hidden");
                } else {
                    leaveBtn.classList.add("hidden");
                }
            }
            
            // ✅ Cập nhật nút Giải tán nhóm
            const disbandBtn = document.getElementById("disbandGroupBtn");
            if (disbandBtn) {
                // Chỉ hiện nếu là group VÀ mình là admin
                if (isGroup && currentAdminId == myId) {
                    disbandBtn.classList.remove("hidden");
                } else {
                    disbandBtn.classList.add("hidden");
                }
            }
            
            // Mobile: Show chat, hide sidebar
            const sidebar = document.getElementById("chatSidebar");
            sidebar.classList.add("hidden");
            sidebar.classList.remove("flex"); // Force remove flex
            
            const chatMain = document.getElementById("chatMain");
            chatMain.classList.remove("hidden");
            chatMain.classList.add("flex");
        }
        
        function backToList() {
            const sidebar = document.getElementById("chatSidebar");
            sidebar.classList.remove("hidden");
            sidebar.classList.add("flex"); // Restore flex

            const chatMain = document.getElementById("chatMain");
            chatMain.classList.add("hidden");
            chatMain.classList.remove("flex");
        }
        async function handleConversationClick(conversationId, otherUserId, name, isGroup, adminId) {
            if (conversationId && conversationId !== "0" && conversationId !== "null") {
                await openConversation(conversationId, otherUserId, name, isGroup, adminId);
            } else {
                // Không có conversationId → tìm xem đã có chưa, nếu chưa thì tạo mới
                const existing = document.querySelector(`.conv-item[data-otherid='${otherUserId}']`);
                if (existing) {
                    const convId = existing.dataset.convid;
                    const adminId = existing.dataset.adminid;
                    await openConversation(convId, otherUserId, name, isGroup, adminId);
                } else {
                    await startChat(otherUserId);
                }
            }
        }
        async function markConversationAsRead(convId) {
            const unreadBadge = document.getElementById(`unread-${convId}`);
            const convItem = document.querySelector(`.conv-item[data-convid='${convId}']`);

            if (unreadBadge) {
                unreadBadge.classList.add("hidden");
                unreadBadge.textContent = "0";
            }
            if (convItem) {
                convItem.classList.remove("font-extrabold");
                convItem.querySelectorAll("div").forEach(el => {
                    if (el.classList.contains("font-semibold")) el.classList.remove("font-extrabold", "text-gray-900", "dark:text-white");
                    if (el.classList.contains("text-sm")) el.classList.remove("text-gray-900", "dark:text-white");
                    // Fix: Remove bold from message preview as well
                    if (el.classList.contains("text-xs")) {
                        el.classList.remove("font-bold", "text-gray-900", "dark:text-white");
                    }
                });
            }

            // Gọi Hub để đánh dấu đã đọc (Realtime & Fast)
            try {
                // Invoke Hub Method
                const totalUnread = await chatConnection.invoke("MarkAsRead", parseInt(convId));
                
                // Update UI with returned count
                const messageCount = document.getElementById("message-count");
                if (messageCount) {
                    messageCount.textContent = totalUnread > 99 ? "99+" : totalUnread;
                    messageCount.style.display = totalUnread > 0 ? "flex" : "none";
                }
            } catch (err) {
                console.error("MarkAsRead SignalR Error: ", err);
            }
        }
        function moveConversationToTop(conversationId) {
            const convEl = document.querySelector(`.conv-item[data-convid='${conversationId}']`);
            if (convEl) {
                const parent = document.getElementById("conversationList");
                parent.prepend(convEl);
                // Lưu thứ tự mới vào localStorage
                const order = Array.from(parent.children).map(el => el.dataset.convid);
                localStorage.setItem("conversationOrder", JSON.stringify(order));
            }
        }
        function restoreConversationOrder() {
            const savedOrder = JSON.parse(localStorage.getItem("conversationOrder") || "[]");
            if (savedOrder.length === 0) return;
            const parent = document.getElementById("conversationList");
            const items = Array.from(parent.children);
            // Lặp ngược để prepend đúng thứ tự
            [...savedOrder].reverse().forEach(id => {
                const el = items.find(x => x.dataset.convid === id);
                if (el) parent.prepend(el);
            });
        }
