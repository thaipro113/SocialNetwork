        let pendingFile = null;

        function clearPreview() {
            pendingFile = null;
            document.getElementById("previewContainer").classList.add("hidden");
            document.getElementById("previewImage").src = "";
            document.getElementById("fileInput").value = "";
        }

        async function sendMessage(e) {
            e.preventDefault();
            const txt = document.getElementById("messageInput");
            if (!currentConversationId) return;
            const content = txt.value.trim();
            
            // 1. Send File if exists
            if (pendingFile) {
                await uploadAndSendFile(pendingFile);
                clearPreview();
            }

            // 2. Send Text if exists
            if (!content) return;
            
            try {
                await chatConnection.invoke("SendMessage", parseInt(currentConversationId), content);
                txt.value = "";
                const lastMsgEl = document.getElementById(`msg-${currentConversationId}`);
                const timeEl = document.getElementById(`time-${currentConversationId}`);
                if (lastMsgEl) lastMsgEl.innerHTML = `<strong>Bạn:</strong> ${content}`;
                if (timeEl) timeEl.textContent = formatDetailTime(new Date());
                moveConversationToTop(currentConversationId);
            } catch (err) {
                console.error("Send Message Error: ", err);
                alert("Lỗi khi gửi tin nhắn: " + err.message);
            }
        }
        function appendMessage(m, senderId) {
            // Check for system message
            if (m.content && m.content.startsWith("[system]") && m.content.endsWith("[/system]")) {
                const sysContent = m.content.replace("[system]", "").replace("[/system]", "");
                const outer = document.createElement("div");
                outer.className = "flex justify-center my-2";
                outer.innerHTML = `<span class="text-xs text-gray-500 bg-gray-200 dark:bg-gray-700 px-2 py-1 rounded-full">${sysContent}</span>`;
                document.getElementById("messages").appendChild(outer);
                return;
            }

            const outer = document.createElement("div");
            outer.className = senderId == myId ? "flex justify-end" : "flex justify-start";
            const isMine = senderId == myId;
            let contentHtml = m.content;
            let isMedia = false;
            // Render ảnh/file/video nếu là nội dung đặc biệt
            if (typeof contentHtml === 'string') {
                const imgMatch = contentHtml.match(/^\[img\](.*)\[\/img\]$/i);
                const videoMatch = contentHtml.match(/^\[video\](.*)\[\/video\]$/i);
                const fileMatch = contentHtml.match(/^\[file\](.*)\|(.*)\[\/file\]$/i);
                if (imgMatch) {
                    isMedia = true;
                    const url = imgMatch[1];
                    contentHtml = `<img src="${url}" class="max-w-xs rounded-lg border cursor-pointer hover:opacity-95 transition" onclick="window.open('${url}', '_blank')" />`;
                } else if (videoMatch) {
                    isMedia = true;
                    const url = videoMatch[1];
                    contentHtml = `<video src="${url}" controls class="max-w-xs rounded-lg border bg-black"></video>`;
                } else if (fileMatch) {
                    const name = fileMatch[1];
                    const url = fileMatch[2];
                    const ext = name.split('.').pop().toLowerCase();
                    let iconClass = "fa-solid fa-file text-gray-500";
                    if (['doc', 'docx'].includes(ext)) iconClass = "fa-solid fa-file-word text-blue-600";
                    else if (['xls', 'xlsx'].includes(ext)) iconClass = "fa-solid fa-file-excel text-green-600";
                    else if (['ppt', 'pptx'].includes(ext)) iconClass = "fa-solid fa-file-powerpoint text-red-600";
                    else if (['pdf'].includes(ext)) iconClass = "fa-solid fa-file-pdf text-red-500";
                    else if (['zip', 'rar'].includes(ext)) iconClass = "fa-solid fa-file-zipper text-yellow-600";
                    // File hiển thị dạng thẻ gọn gàng
                    contentHtml = `
                                        <a href="${url}" target="_blank" class="flex items-center gap-3 min-w-[200px] group">
                                            <div class="w-10 h-10 flex items-center justify-center bg-gray-50 rounded-lg group-hover:bg-white transition-colors">
                                                <i class="${iconClass} text-2xl"></i>
                                            </div>
                                            <div class="flex flex-col overflow-hidden">
                                                <span class="text-sm font-medium truncate w-full text-left group-hover:underline ${isMine ? 'text-white' : 'text-gray-800'}">${name}</span>
                                                <span class="text-[10px] text-left ${isMine ? 'text-blue-100' : 'text-gray-400'}">Nhấn để tải về</span>
                                            </div>
                                        </a>`;
                } else {
                    contentHtml = contentHtml.replace(/</g, "&lt;").replace(/>/g, "&gt;");
                }
            }
            const msgId = m.id || m.Id || m.ID || '';
            // Nếu là media (ảnh/video) thì không có padding/background màu
            const bubbleClass = isMedia
                ? "inline-block rounded-2xl overflow-hidden"
                : `inline-block px-4 py-2.5 rounded-2xl shadow-sm ${isMine ? 'bg-blue-600 text-white' : 'bg-white dark:bg-gray-700 text-gray-800 dark:text-white'} break-words max-w-md`;

            // Sender Info for Group Chat (if not mine)
            let senderInfoHtml = "";
            if (!isMine && m.senderName) {
                const avatarUrl = m.senderAvatar || '/Uploads/default-avatar.png';
                senderInfoHtml = `
                <div class="flex items-center gap-2 mb-1">
                    <img src="${avatarUrl}"
                         class="w-6 h-6 rounded-full object-cover"
                         title="${m.senderName}" />
                    <span class="text-xs font-medium text-gray-600 dark:text-gray-400">${m.senderName}</span>
                </div>
            `;
            }
            const bubble = `
                                                <div class="max-w-[70%]" data-msgid="${msgId}">
                                                    ${senderInfoHtml}
                                                    <div class="flex items-center gap-2 ${isMine ? 'flex-row-reverse' : ''}">
                                                        <div class="${bubbleClass}">${contentHtml}</div>
                                                        <div class="relative group/menu">
                                                                           <button class="text-gray-400 hover:text-gray-200 text-sm px-1 transition-colors"
                                                                                    onclick="showMsgMenu(this, ${msgId || 'null'}, ${isMine})">
                                                                                <i class="fas fa-ellipsis-v"></i>
                                                                            </button>
                                                                    <div class="hidden absolute ${isMine ? 'right-0' : 'left-0'} bottom-full mb-2 bg-white border rounded shadow z-10 text-sm" style="min-width:160px;">
                                                                <button class="block w-full text-left px-3 py-2 hover:bg-gray-100" onclick="deleteForMe(${msgId || 'null'}, this)">Thu hồi với bạn</button>
                                                                ${isMine ? '<button class="block w-full text-left px-3 py-2 hover:bg-gray-100 text-red-600" onclick="deleteForEveryone(' + (msgId || 'null') + ', this)">Thu hồi với mọi người</button>' : ''}
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="mt-1 ${isMine ? 'text-right' : 'text-left'} text-[10px] ${isMine ? 'text-blue-500' : 'text-gray-400'}">
                                                        ${formatDetailTime(m.createdAt)}
                                                        ${isMine ? `<span class="message-status ml-1 font-medium">${m.isRead ? "Đã xem" : "Đã gửi"}</span>` : ''}
                                                    </div>
                                                </div>`;
            outer.innerHTML = bubble;
            document.getElementById("messages").appendChild(outer);
        }
        function formatLastMessageContent(content, isMine = false) {
            if (!content) return isMine ? "<strong>Bạn:</strong> đã gửi 1 tệp" : "đã gửi 1 tệp";

            // Xử lý tin nhắn hệ thống
            if (content.startsWith("[system]") && content.endsWith("[/system]")) {
                const systemText = content.replace("[system]", "").replace("[/system]", "");
                return systemText; // Không thêm "Bạn:" cho tin nhắn hệ thống
            }

            if (content.startsWith("[img]") && content.endsWith("[/img]")) {
                return isMine ? "<strong>Bạn:</strong> đã gửi 1 ảnh" : "đã gửi 1 ảnh";
            }
            if (content.startsWith("[video]") && content.endsWith("[/video]")) {
                return isMine ? "<strong>Bạn:</strong> đã gửi 1 video" : "đã gửi 1 video";
            }
            if (content.startsWith("[file]") && content.includes("[/file]")) {
                // Lấy tên file nếu có
                const match = content.match(/\[file\](.*?)\|/);
                const fileName = match ? match[1] : null;
                return isMine
                    ? `<strong>Bạn:</strong> đã gửi 1 tệp${fileName ? `: ${fileName}` : ""}`
                    : `đã gửi 1 tệp${fileName ? `: ${fileName}` : ""}`;
            }

            // Tin nhắn văn bản bình thường
            const plainText = content.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const truncated = plainText.length > 50 ? plainText.substring(0, 47) + "..." : plainText;
            return isMine ? `<strong>Bạn:</strong> ${truncated}` : truncated;
        }
        function deleteForMe(id, el) {
