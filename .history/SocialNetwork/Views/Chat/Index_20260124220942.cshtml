        async function startChat(otherId) {
            // Kiểm tra xem đã có cuộc trò chuyện với người này chưa
            const existingConv = document.querySelector(`.conv-item[data-otherid='${otherId}']`);
            if (existingConv) {
                // Đã có → mở luôn
                const convId = existingConv.dataset.convid;
                await openConversation(convId, otherId);
                return;
            }
            // Chưa có → tạo mới
            try {
                const res = await fetch("/Chat/StartConversation", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(parseInt(otherId))
                });
                const d = await res.json();
                if (!d.success) {
                    alert(d.message || "Không thể bắt đầu chat");
                    return;
                }
                // Tạo phần tử mới
                const friend = friends.find(f => f.UserId == otherId);
                const avatar = friend?.ImageUrl ? `/Uploads/${friend.ImageUrl}` : `/Uploads/default-avatar.png`;
                const newItem = document.createElement("div");
                newItem.className = "conv-item group flex items-center gap-3 p-3 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition border-b dark:border-gray-700";
                newItem.dataset.convid = d.conversationId;
                newItem.dataset.otherid = otherId;
                newItem.dataset.username = friend?.FullName || "Người dùng mới";
                newItem.onclick = () => handleConversationClick(d.conversationId, otherId);
                newItem.innerHTML = `
                    <div class="relative flex-shrink-0">
                        <img src="${avatar}" class="w-14 h-14 rounded-full object-cover" />
                        <span class="absolute bottom-0 right-0 block w-3.5 h-3.5 rounded-full bg-green-500 ring-2 ring-white"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between mb-1">
                            <h3 class="font-semibold text-sm text-gray-800 dark:text-gray-200 truncate">${friend?.FullName || "Người dùng mới"}</h3>
                            <span class="text-[11px] text-gray-400 flex-shrink-0" id="time-${d.conversationId}"></span>
                        </div>
                        <div class="flex items-center justify-between">
                            <p class="text-xs text-gray-500 dark:text-gray-400 truncate flex-1" id="msg-${d.conversationId}">Không có tin nhắn</p>
                            <span id="unread-${d.conversationId}" class="hidden bg-blue-600 text-white text-[10px] font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1 flex-shrink-0">0</span>
                        </div>
                    </div>
                    <button onclick="deleteConversation(event, '${d.conversationId}')"
                            class="opacity-0 group-hover:opacity-100 text-gray-400 hover:text-red-500 transition absolute right-3 top-1/2 -translate-y-1/2" title="Xóa đoạn chat">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                // Thêm vào đầu danh sách
                const list = document.getElementById("conversationList");
                list.prepend(newItem);
                // Lưu thứ tự
                const order = Array.from(list.children).map(el => el.dataset.convid);
                localStorage.setItem("conversationOrder", JSON.stringify(order));
                // Mở khung chat
                await openConversation(d.conversationId, otherId);
            } catch (err) {
                console.error("Start Chat Error: ", err);
            }
        }
