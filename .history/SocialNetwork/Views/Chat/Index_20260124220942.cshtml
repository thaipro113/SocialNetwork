            if (msgContainer) msgContainer.remove();
            // CẬP NHẬT LAST MESSAGE BÊN MÌNH NẾU TIN BỊ XÓA LÀ TIN CUỐI
            if (currentConversationId) {
                updateLocalLastMessageAfterDelete();
            }
        }
