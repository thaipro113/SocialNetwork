@model SocialNetwork.Models.Post
@using Microsoft.AspNetCore.Http
@using System.Text.RegularExpressions
@inject IHttpContextAccessor HttpContextAccessor
@functions {
    public Microsoft.AspNetCore.Html.IHtmlContent RenderContent(string content)
    {
        if (string.IsNullOrEmpty(content)) return Html.Raw("");
        var encoded = System.Net.WebUtility.HtmlEncode(content);
        var replaced = Regex.Replace(encoded, 
            @"\{\{mention:(\d+):(.*?)\}\}", 
            "<a href=\"/User/Profile/$1\" class=\"text-blue-600 font-semibold hover:underline\">$2</a>");
        return Html.Raw(replaced);
    }
}
@{
    var currentUserId = HttpContextAccessor.HttpContext.Session.GetInt32("UserId");
    var rootComments = Model.Comments.Where(c => c.ParentCommentId == null).OrderBy(c => c.CreatedAt);
}

@foreach (var comment in rootComments)
{
    var avatarFileName = comment.User?.ImageUrl;
    var avatarUrl = string.IsNullOrEmpty(avatarFileName)
        ? Url.Content("~/uploads/default-avatar.png")
        : Url.Content($"~/uploads/{avatarFileName}");

    var hasReplies = Model.Comments.Any(c => c.ParentCommentId == comment.CommentId);

    // ROOT COMMENT
    <div class="flex items-start space-x-3 mb-3" id="comment-@comment.CommentId">
        <a href="@Url.Action("Profile","User", new { id = comment.UserId })">
            <img src="@avatarUrl" alt="Avatar"
                 class="w-10 h-10 rounded-full object-cover hover:ring-2 hover:ring-purple-500 transition-all" />
        </a>

        <div class="flex-1">
            <div class="bg-gray-100 dark:bg-gray-700 rounded-lg px-3 py-2 inline-block">
                <p class="font-semibold text-sm dark:text-white">
                    <a href="@Url.Action("Profile","User", new { id = comment.UserId })">@comment.User?.FullName</a>
                </p>
                <p class="text-sm text-gray-700 dark:text-white">@comment.Content</p>
            </div>
            
            <div class="flex items-center space-x-4 mt-1 ml-2 text-xs text-gray-500 dark:text-gray-400">
                <span class="time-ago" data-time="@comment.CreatedAt?.ToString("o")"></span>
                
                @if (currentUserId != null)
                {
                    <button type="button" class="font-semibold hover:underline" onclick="toggleReplyForm(@comment.CommentId)">Phản hồi</button>
                }

                @if (currentUserId == comment.UserId || currentUserId == Model.UserId)
                {
                    <button type="button"
                            class="text-red-500 delete-comment-btn"
                            data-comment-id="@comment.CommentId"
                            data-post-id="@Model.PostId">
                        Xóa
                    </button>
                }
            </div>

            <!-- REPLIES -->
            @{
                var replies = Model.Comments.Where(c => c.ParentCommentId == comment.CommentId).OrderBy(c => c.CreatedAt);
            }
            @if (replies.Any())
            {
                <div class="mt-3 space-y-3 pl-2 sm:pl-4 border-l-2 border-gray-200 dark:border-gray-600">
                    @foreach (var reply in replies)
                    {
                        var rAvatar = reply.User?.ImageUrl;
                        var rAvatarUrl = string.IsNullOrEmpty(rAvatar)
                            ? Url.Content("~/uploads/default-avatar.png")
                            : Url.Content($"~/uploads/{rAvatar}");

                         <div class="flex items-start space-x-3" id="comment-@reply.CommentId">
                            <a href="@Url.Action("Profile","User", new { id = reply.UserId })">
                                <img src="@rAvatarUrl" alt="Avatar"
                                     class="w-8 h-8 rounded-full object-cover hover:ring-2 hover:ring-purple-500 transition-all" />
                            </a>
                            <div class="flex-1">
                                <div class="bg-gray-100 dark:bg-gray-700 rounded-lg px-3 py-2 inline-block">
                                    <p class="font-semibold text-sm dark:text-white">
                                        <a href="@Url.Action("Profile","User", new { id = reply.UserId })">@reply.User?.FullName</a>
                                    </p>
                                    <p class="text-sm text-gray-700 dark:text-white">@reply.Content</p>
                                </div>
                                <div class="flex items-center space-x-4 mt-1 ml-2 text-xs text-gray-500 dark:text-gray-400">
                                    <span class="time-ago" data-time="@reply.CreatedAt?.ToString("o")"></span>
                                    
                                    @if (currentUserId != null)
                                    {
                                        <button type="button" class="font-semibold hover:underline" 
                                                onclick="prepareReply(@comment.CommentId, '@reply.User?.FullName', @reply.UserId)">
                                            Phản hồi
                                        </button>
                                    }

                                     @if (currentUserId == reply.UserId || currentUserId == Model.UserId)
                                    {
                                        <button type="button"
                                                class="text-red-500 delete-comment-btn"
                                                data-comment-id="@reply.CommentId"
                                                data-post-id="@Model.PostId">
                                            Xóa
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- REPLY FORM -->
            <div id="reply-form-container-@comment.CommentId" class="hidden mt-2">
                 @{
                    var myAvatarName = HttpContextAccessor.HttpContext.Session.GetString("ImageUrl");
                    var myAvatarUrl = string.IsNullOrEmpty(myAvatarName)
                        ? Url.Content("~/uploads/default-avatar.png")
                        : Url.Content($"~/uploads/{myAvatarName}");
                 }
                 <form class="reply-form flex items-center space-x-2" data-post-id="@Model.PostId" data-parent-id="@comment.CommentId">
                    <img src="@myAvatarUrl" class="w-8 h-8 rounded-full object-cover">
                    <input type="text" name="content" placeholder="Viết phản hồi..."
                           class="flex-1 border dark:border-gray-600 rounded-lg px-3 py-1 text-sm focus:ring-2 focus:ring-purple-500 dark:bg-gray-800 dark:text-white" />
                    <button type="button" onclick="submitReply(this, @Model.PostId, @comment.CommentId)" class="text-blue-600 font-semibold text-sm">Gửi</button>
                </form>
            </div>

        </div>
    </div>
}
