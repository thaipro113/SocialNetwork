    </footer>

    <!-- Modal: Cuộc gọi bị từ chối -->
    <div id="callRejectedModal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-8 text-center max-w-sm animate-bounce-in">
            <div class="text-6xl mb-4">
                <i class="fa-solid fa-phone-slash text-red-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-2">Cuộc gọi bị từ chối</h3>
            <p class="text-gray-600 mb-6">Người dùng không muốn nhận cuộc gọi lúc này.</p>
            <button onclick="closeCallRejectedModal()" class="px-6 py-3 bg-gray-600 text-white rounded-full hover:bg-gray-700 transition">
                Đóng
            </button>
        </div>
    </div>

    <!-- Modal: Cuộc gọi đã kết thúc -->
    <div id="callEndedModal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-8 text-center max-w-sm animate-bounce-in">
            <div class="text-6xl mb-4">
                <i class="fa-solid fa-phone-slash text-orange-500"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-2">Cuộc gọi đã kết thúc</h3>
            <p class="text-gray-600 mb-6">Cuộc gọi video đã được kết thúc.</p>
            <button onclick="closeCallEndedModal()" class="px-6 py-3 bg-gray-600 text-white rounded-full hover:bg-gray-700 transition">
                Đóng
            </button>
        </div>
    </div>
    <!-- Video Call Modal (Global) -->
    <partial name="_VideoCallModal" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

 <script>
    // ========================================
    // 1. SIGNALR CONNECTIONS
    // ========================================
    const chatConnection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .configureLogging(signalR.LogLevel.Information)
        .build();
    window.chatConnection = chatConnection; // Expose globally

    const notificationConnection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .configureLogging(signalR.LogLevel.Information)
        .build();

        // Start connections
        const startPromise = Promise.all([
            chatConnection.start().catch(err => console.error("ChatHub Error:", err)),
            notificationConnection.start().catch(err => console.error("NotificationHub Error:", err))
        ]).then(() => {
            console.log("SignalR Hubs Connected");
        });
        window.chatConnectionPromise = startPromise; // Expose promise globally

    // ========================================
    // 2. SIGNALR EVENT LISTENERS
    // ========================================
    chatConnection.on("ReceiveMessage", () => {
        updateMessageCount();
        if (!document.getElementById("messageDropdown").classList.contains("hidden")) {
            loadUnreadMessages();
        }
    });
    // Trong <script> của View
chatConnection.on("UpdateLastMessage", (data) => {
    const { conversationId, lastMessage } = data;
    const msgEl = document.getElementById(`msg-${conversationId}`);
    const timeEl = document.getElementById(`time-${conversationId}`);

    if (!msgEl) return;

    if (lastMessage) {
        const isMine = lastMessage.senderId == myId;
        msgEl.innerHTML = isMine 
            ? `<strong>Bạn:</strong> ${lastMessage.content}`
            : lastMessage.content;
        timeEl.textContent = new Date(lastMessage.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    } else {
        msgEl.innerHTML = "Không có tin nhắn";
        timeEl.textContent = "";
    }

    // Đưa lên đầu nếu đang mở
    if (currentConversationId == conversationId) {
        moveConversationToTop(conversationId);
    }
});

    chatConnection.on("UserOnline", (userId) => {
        loadFriendSummary();
    });

    chatConnection.on("UserOffline", (userId) => {
        loadFriendSummary();
    });
    notificationConnection.on("ReceiveNotification", (notification) => {
        updateNotificationCount();
        if (!document.getElementById("notificationDropdown").classList.contains("hidden")) {
            prependNotification(notification);
        }
    });

    notificationConnection.on("FriendAccepted", (data) => {
        showToast(data.message);
        updateNotificationCount();
        loadFriendSummary(); // Cập nhật lại gợi ý + bạn bè
    });

    notificationConnection.on("RemoveNotification", (notiId) => {
        document.querySelector(`[data-notification-id="${notiId}"]`)?.remove();
        updateNotificationCount();
    });

    // ========================================
    // 3. DOM READY & INITIAL LOAD
    // ========================================
    document.addEventListener("DOMContentLoaded", () => {
        updateNotificationCount();
        updateMessageCount();
        loadFriendSummary();
        observeCardAnimations();
    });

    function observeCardAnimations() {
        const cards = document.querySelectorAll(".card-hover");
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = "1";
                    entry.target.style.transform = "translateY(0)";
                }
            });
        }, { threshold: 0.1 });

        cards.forEach(card => observer.observe(card));
    }

    // ========================================
    // 4. NOTIFICATION SYSTEM
    // ========================================
    function updateNotificationCount() {
        fetch("/Notification/GetNotifications")
            .then(r => r.json())
            .then(data => {
                if (!data.success) return;
                const badge = document.getElementById("notification-count");
                const count = data.unread;
                badge.textContent = count > 99 ? "99+" : count;
                badge.style.display = count > 0 ? "flex" : "none";
            });
    }

    function toggleNotificationDropdown() {
        const dropdown = document.getElementById("notificationDropdown");
        dropdown.classList.toggle("hidden");

        if (!dropdown.classList.contains("hidden")) {
            loadNotifications();
        }
    }

    function loadNotifications() {
        fetch("/Notification/GetNotifications")
            .then(r => r.json())
            .then(data => {
                if (!data.success) return;
                const list = document.getElementById("notification-list");
                list.innerHTML = "";
                const deleteAllBtn = document.getElementById("deleteAllBtn");
                deleteAllBtn.style.display = data.data.length > 0 ? "block" : "none";

                // API trả về mới → cũ → cần đảo ngược để prepend đúng thứ tự
                [...data.data].reverse().forEach(notif => prependNotification(notif));
            });
    }

    function prependNotification(n) {
        const notifId = n.Id ?? n.id;
        const type = n.Type ?? n.type;
        let message = n.Message ?? n.message;
        message = message.replace(/\{\{mention:\d+:(.*?)\}\}/g, '<span class="text-blue-600 font-semibold">@@$1</span>');
        const isRead = n.IsRead ?? n.isRead;
        const createdAt = n.createdAt ?? new Date(n.CreatedAt).toLocaleString('vi-VN');
        const postId = n.PostId ?? n.postId ?? 0;
        const requestId = n.FriendRequestId ?? n.friendRequestId ?? 0;
        const from = n.fromUser ?? n.FromUser ?? {};
        const avatar = from.avatar ?? from.Avatar ?? '/Uploads/default-avatar.png';
        const fullName = from.fullName ?? from.name ?? from.FullName ?? from.Name ?? 'Người dùng';

        const list = document.getElementById("notification-list");
        const item = document.createElement("div");
        item.className = `p-3 border-b transition cursor-pointer ${!isRead ? "bg-blue-50 dark:bg-blue-900/20" : "hover:bg-gray-50 dark:hover:bg-gray-700"}`;
        item.dataset.notificationId = notifId;

        if (type === "friend_request") {
            item.innerHTML = `
            <div class="flex items-center gap-3">
                <div class="relative">
                    <img src="${avatar}" class="w-10 h-10 rounded-full flex-shrink-0 object-cover">
                    <div class="absolute -bottom-1 -right-1 bg-blue-500 rounded-full p-1 border-2 border-white dark:border-gray-800">
                        <i class="fa-solid fa-user-plus text-white text-[10px]"></i>
                    </div>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-sm text-gray-700 dark:text-gray-200"><b>${fullName}</b> ${message}</div>
                    <div class="text-xs text-gray-400 mt-1">${createdAt}</div>
                    <div class="mt-2 flex gap-2">
                        <button onclick="event.stopPropagation(); acceptFriend(${requestId}, ${notifId})"
                                class="px-3 py-1.5 bg-blue-600 text-white text-xs font-medium rounded-lg hover:bg-blue-700 transition shadow-sm">
                            Chấp nhận
                        </button>
                        <button onclick="event.stopPropagation(); declineFriend(${requestId}, ${notifId})"
                                class="px-3 py-1.5 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-xs font-medium rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition">
                            Từ chối
                        </button>
                    </div>
                </div>
                <button onclick="event.stopPropagation(); deleteNotification(${notifId})"
                        class="text-gray-400 hover:text-red-500 transition ml-2 p-1 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700">✕</button>
            </div>`;

            item.onclick = function (e) {
                if (!e.target.closest('button')) {
                    markNotificationAsRead(notifId);
                    window.location.href = "/Friend/Index"; // Or user profile
                }
            };
        } else {
            // Determine icon
            let icon = '<i class="fa-solid fa-bell text-white text-[10px]"></i>';
            let bg = 'bg-gray-500';
            
            if (type === 'comment') {
                icon = '<i class="fa-solid fa-comment text-white text-[10px]"></i>';
                bg = 'bg-green-500';
            } else if (type === 'reply') {
                icon = '<i class="fa-solid fa-reply text-white text-[10px]"></i>';
                bg = 'bg-purple-500';
            } else if (type === 'like') { 
                 // Fix: Change to Blue Thumbs Up
                 icon = '<i class="fa-solid fa-thumbs-up text-white text-[10px]"></i>';
                 bg = 'bg-blue-600';
            }

            item.innerHTML = `
                <div class="flex items-center gap-3 cursor-pointer" onclick="goToPost(${postId})">
                    <div class="relative">
                        <img src="${avatar}" class="w-10 h-10 rounded-full flex-shrink-0 object-cover">
                        <div class="absolute -bottom-1 -right-1 ${bg} rounded-full p-1 border-2 border-white dark:border-gray-800 flex items-center justify-center w-5 h-5">
                            ${icon}
                        </div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm text-gray-700 dark:text-gray-200"><b>${fullName}</b> ${message}</div>
                        <div class="text-xs text-gray-400 mt-1">${createdAt}</div>
                    </div>
                    <button onclick="event.stopPropagation(); deleteNotification(${notifId})"
                            class="text-gray-400 hover:text-red-500 transition p-1 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700">✕</button>
                </div>`;
            
            item.onclick = (e) => {
                if (e.target.tagName !== 'BUTTON' && !e.target.closest('button')) {
                    markNotificationAsRead(notifId);
                    goToPost(postId);
                }
            };
        }
        list.prepend(item);
    }

    function markNotificationAsRead(id) {
        fetch(`/Notification/MarkAsRead?id=${id}`, { method: "POST" })
            .then(r => r.json())
            .then(d => { if (d.success) updateNotificationCount(); });
    }

    function markAllAsRead() {
        fetch("/Notification/MarkAsRead", { method: "POST" })
            .then(r => r.json())
            .then(d => { if (d.success) { updateNotificationCount(); toggleNotificationDropdown(); } });
    }

    function deleteNotification(id) {
        showGlobalConfirm(
            "Xóa thông báo",
            "Bạn có chắc muốn xóa thông báo này?",
            () => {
                fetch(`/Notification/Delete?id=${id}`, { method: "POST" })
                    .then(r => r.json())
                    .then(d => { 
                        if (d.success) { 
                             // Remove from DOM immediately
                             const el = document.querySelector(`[data-notification-id="${id}"]`);
                             if (el) el.remove();
                             // Fetch count update
                             updateNotificationCount(); 
                        } 
                    });
            }
        );
    }

    function deleteAllNotifications() {
        showGlobalConfirm(
            "Xóa tất cả",
            "Bạn có chắc muốn xóa TẤT CẢ thông báo?",
            () => {
                fetch("/Notification/DeleteAll", { method: "POST" })
                    .then(r => r.json())
                    .then(d => { if (d.success) { updateNotificationCount(); toggleNotificationDropdown(); } });
            }
        );
    }

    function acceptFriend(requestId, notiId) {
        fetch('/Friend/Accept', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(requestId) })
            .then(r => r.json())
            .then(d => { if (d.success) { document.querySelector(`[data-notification-id="${notiId}"]`)?.remove(); updateNotificationCount(); loadFriendSummary(); } });
    }

    function declineFriend(requestId, notiId) {
        fetch('/Friend/Decline', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(requestId) })
            .then(r => r.json())
            .then(d => { if (d.success) { document.querySelector(`[data-notification-id="${notiId}"]`)?.remove(); updateNotificationCount(); } });
    }

    function goToPost(postId) {
        if (postId) window.location.href = `/Post/Details/${postId}`;
    }

    // ========================================
    // 5. MESSAGE SYSTEM
    // ========================================
    function updateMessageCount() {
        fetch("/Chat/GetUnreadMessageCount")
            .then(r => r.json())
            .then(data => {
                if (!data.success) return;
                const badge = document.getElementById("message-count");
                const count = data.unread;
                badge.textContent = count > 99 ? "99+" : count;
                badge.style.display = count > 0 ? "flex" : "none";
            });
    }

    function toggleMessageDropdown() {
        const dropdown = document.getElementById("messageDropdown");
        dropdown.classList.toggle("hidden");

        if (!dropdown.classList.contains("hidden")) {
            loadUnreadMessages();
        }
    }

    function loadUnreadMessages() {
        fetch("/Chat/GetUnreadMessages")
            .then(r => r.json())
            .then(data => {
                if (!data.success) return;
                const list = document.getElementById("message-list");
                list.innerHTML = "";
                data.data.forEach(item => addMessageItem(item));
            });
    }

    function addMessageItem(item) {
        const list = document.getElementById("message-list");
        const div = document.createElement("div");
        
        // Thêm viền xanh nếu chưa đọc (giống thông báo bài viết)
        const isUnread = !item.message.isRead;
        div.className = `p-3 border-b dark:border-gray-700 transition cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 ${isUnread ? "bg-blue-50 dark:bg-blue-900/20 border-l-4 border-l-blue-500" : ""}`;
        
        let avatar = item.sender.avatar || '/Uploads/default-avatar.png';
        let title = item.sender.fullName;
        let content = item.message.content;

        if (item.isGroup) {
            avatar = item.groupAvatar || '/Uploads/default-group.png';
            title = item.groupName;
            content = `<strong>${item.sender.fullName}:</strong> ${item.message.content}`;
        }

        // Xử lý nội dung tin nhắn đặc biệt
        if (content.startsWith("[img]")) {
            content = "đã gửi 1 ảnh";
        } else if (content.startsWith("[video]")) {
            content = "đã gửi 1 video";
        } else if (content.startsWith("[file]")) {
            content = "đã gửi 1 tệp";
        } else if (content.startsWith("[system]")) {
            content = content.replace("[system]", "").replace("[/system]", "");
        }

        div.innerHTML = `
            <div class="flex items-center gap-3">
                <img src="${avatar}" class="w-10 h-10 rounded-full object-cover flex-shrink-0">
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-bold text-gray-800 dark:text-gray-200 truncate">${title}</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400 truncate">${content}</div>
                    <div class="text-xs text-gray-500 dark:text-gray-500">${new Date(item.message.createdAt).toLocaleString('vi-VN')}</div>
                </div>
            </div>`;
        div.onclick = () => {
            markMessageAsRead(item.conversationId);
            window.location.href = `/Chat/Index?c=${item.conversationId}`;
        };
        list.appendChild(div);
    }

    function markMessageAsRead(conversationId) {
        fetch("/Chat/MarkAsRead", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(conversationId) })
            .then(r => r.json())
            .then(d => { if (d.success) updateMessageCount(); });
    }

    function markAllMessagesAsRead() {
        fetch("/Chat/MarkAllMessagesAsRead", { method: "POST" })
            .then(r => r.json())
            .then(d => { if (d.success) { updateMessageCount(); toggleMessageDropdown(); } });
    }

    // ========================================
    // 6. FRIEND SYSTEM & SIDEBAR
    // ========================================
    async function loadFriendSummary() {
        try {
            const res = await fetch('/Friend/GetFriendSummary');
            const d = await res.json();
            if (!d.success) return;

            // Stats
            setText("stat-posts", d.postCount ?? 0);
            setText("stat-friends", d.friendCount ?? 0);

            // Online friends
            const onlineEl = document.getElementById("online-friends");
            onlineEl.innerHTML = "";
            if (d.onlineFriends?.length > 0) {
                d.onlineFriends?.forEach(f => {
                    const row = createOnlineFriendRow(f);
                    onlineEl.appendChild(row);
                });
            } else {
                onlineEl.innerHTML = '<div class="text-sm text-gray-500">Không có bạn bè nào đang online</div>';
            }

            // Friend suggestions
            const suggestEl = document.getElementById("suggest-card-list");
            suggestEl.innerHTML = "";
            d.suggestions?.forEach(s => {
                const card = createSuggestionCard(s);
                suggestEl.appendChild(card);
            });
        } catch (e) { console.error(e); }
    }

        function createOnlineFriendRow(f) {
            const row = document.createElement("div");
            row.className = "flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 cursor-pointer";

            row.innerHTML = `
                <div class="relative flex-shrink-0">
                    <img src="${f.avatar || '/Uploads/default-avatar.png'}"
                         class="w-11 h-11 rounded-full object-cover ring-2 ring-white shadow-sm">
                    <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 rounded-full border-2 border-white"></div>
                </div>

                <div class="flex-1 min-w-0">
                    <!-- Tên nằm thẳng hàng với avatar -->
                    <a href="/User/Profile/${f.userId}"
                       class="font-semibold text-gray-900 dark:text-gray-100 hover:text-blue-600 text-sm line-clamp-1 block leading-tight">
                        ${f.fullName}
                    </a>
                    <!-- Đang hoạt động nhỏ gọn bên dưới -->
                 <div class="flex items-center gap-1.5 text-xs text-green-600 dark:text-green-400 font-medium">
                  <span class="whitespace-nowrap">Đang hoạt động</span>
                </div>
                </div>

                <!-- Nút Chat nhỏ gọn, đẹp như Facebook -->
                <button onclick="event.stopPropagation(); startChat(${f.userId})"
                        class="px-2.5 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold rounded-lg shadow-md hover:shadow-lg transition-all duration-200 flex-shrink-0">
                    Chat
                </button>
            `;

            // Click toàn bộ dòng → mở profile
            row.onclick = (e) => {
                if (!e.target.closest('button')) {
                    window.location.href = `/User/Profile/${f.userId}`;
                }
            };

            return row;
        }

    function createSuggestionCard(s) {
        const card = document.createElement("div");
        card.className = "p-4 bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100";

        let buttonHTML = "";
        if (s.isSent) {
            buttonHTML = getSentButton();
        } else if (s.hasIncomingRequest) {
            buttonHTML = getIncomingRequestButtons(s);
        } else {
            buttonHTML = getAddFriendButton(s.userId);
        }

        card.innerHTML = `
            <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-4 flex-1 min-w-0">
                    <div class="relative flex-shrink-0">
                        <a href="/User/Profile/${s.userId}"><img src="${s.avatar}" class="w-14 h-14 rounded-full object-cover ring-2 ring-pink-200 shadow-md"></a>
                        ${s.online ? '<div class="absolute bottom-0 right-0 w-4 h-4 bg-green-400 rounded-full border-3 border-white animate-pulse"></div>' : ''}
                    </div>
                    <div class="min-w-0">
        <a href="/User/Profile/${s.userId}"
           class="block font-semibold text-gray-800 dark:text-gray-200 hover:text-purple-600 text-sm break-words transition-colors">
           ${s.fullName}
        </a>
                        <div class="text-xs text-gray-500">${s.mutual > 0 ? s.mutual + ' bạn chung' : 'Người mới'}</div>
                    </div>
                </div>
                <div id="btn-${s.userId}" class="flex-shrink-0">${buttonHTML}</div>
            </div>`;
        return card;
    }

    function getSentButton() {
        return `<button class="w-13 px-4 py-3 bg-gray-500 text-white font-bold text-sm rounded-xl shadow-inner cursor-not-allowed flex items-center justify-center gap-1" disabled>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
                    Đã gửi
                </button>`;
