    function getAddFriendButton(userId) {
        return `<button onclick="sendFriendRequest(${userId}, this)" class="w-13 px-2 py-2 bg-blue-600 hover:from-blue-600 hover:to-purple-700 text-white font-bold text-sm rounded-xl shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300">
                    Kết bạn
                </button>`;
    }

        async function sendFriendRequest(toUserId, button) {
            if (!button) return;
            button.disabled = true;
            button.innerHTML = "Đang gửi...";

            try {
                const res = await fetch("/Friend/SendRequest", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: `toUserId=${toUserId}`
                });
                const d = await res.json();

                if (d.success) {
                    // Xóa luôn thẻ gợi ý của người này khỏi giao diện
                    const suggestionCard = button.closest('[id^="suggest-card-list"] > div');
                    if (suggestionCard) {
                        suggestionCard.style.transition = "all 0.3s";
                        suggestionCard.style.opacity = "0";
                        suggestionCard.style.transform = "scale(0.95)";
                        setTimeout(() => suggestionCard.remove(), 300);
                    }

                    showToast("Đã gửi lời mời kết bạn!");

                    // Tải lại danh sách gợi ý (đảm bảo không hiện lại người vừa gửi)
                    setTimeout(loadFriendSummary, 500);
                } else {
                    alert(d.message || "Lỗi");
                    button.innerHTML = "Kết bạn";
                    button.disabled = false;
                }
            } catch (e) {
                alert("Lỗi mạng!");
                button.innerHTML = "Kết bạn";
                button.disabled = false;
            }
        }

    async function startChat(userId) {
        try {
            const res = await fetch("/Chat/StartConversation", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(parseInt(userId))
            });
            const d = await res.json();
            if (d.success) window.location.href = `/Chat/Index?c=${d.conversationId}`;
        } catch (e) {
            alert("Lỗi mở chat");
        }
    }

    // ========================================
    // 7. UI INTERACTIONS (Modal, Dropdown, Toast)
    // ========================================
    function openPostModal() {
        const modal = document.getElementById("postModal");
        modal.classList.remove("hidden");
        modal.classList.add("flex");
    }

    function closePostModal() {
        const modal = document.getElementById("postModal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        document.getElementById("mediaInput").value = "";
        document.getElementById("preview-container").classList.add("hidden");
    }

    function toggleDropdown() {
        document.getElementById("userDropdown").classList.toggle("hidden");
    }

    function previewFile(event) {
        const file = event.target.files[0];
        if (!file) return;
        const url = URL.createObjectURL(file);
        const container = document.getElementById("preview-container");
        const img = document.getElementById("preview-img");
        const video = document.getElementById("preview-video");

        container.classList.remove("hidden");
        if (file.type.startsWith("image")) {
            img.src = url; img.classList.remove("hidden"); video.classList.add("hidden");
        } else if (file.type.startsWith("video")) {
            video.src = url; video.classList.remove("hidden"); img.classList.add("hidden");
        }
    }

    function showToast(html) {
        const toast = document.createElement("div");
        toast.className = "fixed bottom-6 right-6 bg-green-600 text-white px-6 py-4 rounded-xl shadow-2xl z-50 transform transition-all duration-500 translate-y-10 opacity-0";
        toast.innerHTML = html;
        document.body.appendChild(toast);
        setTimeout(() => toast.classList.remove("translate-y-10", "opacity-0"), 100);
        setTimeout(() => {
            toast.classList.add("translate-y-10", "opacity-0");
            setTimeout(() => toast.remove(), 500);
        }, 3500);
    }

    // Close dropdowns when clicking outside
    document.addEventListener("click", (e) => {
        closeIfOutside(e, "notificationDropdown", "a[onclick='toggleNotificationDropdown()']");
        closeIfOutside(e, "messageDropdown", "a[onclick='toggleMessageDropdown()']");
        closeIfOutside(e, "userDropdown", ".flex.items-center.space-x-2.cursor-pointer");
    });

    function closeIfOutside(e, dropdownId, triggerSelector) {
        const dropdown = document.getElementById(dropdownId);
        const trigger = document.querySelector(triggerSelector);
        if (dropdown && !dropdown.contains(e.target) && (!trigger || !trigger.contains(e.target))) {
            dropdown.classList.add("hidden");
        }
    }

    // Close modal when clicking backdrop
    document.getElementById("postModal")?.addEventListener("click", (e) => {
        if (e.target.id === "postModal") closePostModal();
    });

    // Helper
    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    }

        // MOBILE MENU TOGGLE
        const mobileBtn = document.getElementById("mobileMenuBtn");
        const mobileMenu = document.getElementById("mobileMenu");
        const mobileMenuPanel = document.getElementById("mobileMenuPanel");
        const closeMobile = document.getElementById("closeMobileMenu");

        function openMobileMenu() {
            mobileMenu.classList.remove("hidden");
            // Force reflow
            mobileMenu.offsetHeight;
            mobileMenu.classList.remove("opacity-0");
            mobileMenuPanel.classList.remove("-translate-x-full");
        }

        function closeMobileMenuFunc() {
            mobileMenu.classList.add("opacity-0");
            mobileMenuPanel.classList.add("-translate-x-full");
            setTimeout(() => {
                mobileMenu.classList.add("hidden");
            }, 300); // Đợi animation kết thúc
        }

        mobileBtn?.addEventListener("click", openMobileMenu);
        closeMobile?.addEventListener("click", closeMobileMenuFunc);

        // Đóng khi click ngoài
        mobileMenu?.addEventListener("click", (e) => {
            if (e.target === mobileMenu) {
                closeMobileMenuFunc();
            }
        });
        // ========================================
        // DARK MODE TOGGLE LOGIC
        // ========================================
        // Dark Mode Toggle - CHỈ DÙNG 1 ICON
        const themeToggle = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');

        // Kiểm tra theme hiện tại và set icon đúng
        if (localStorage.getItem('theme') === 'dark' ||
            (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            themeIcon.classList.replace('fa-moon', 'fa-sun'); // Đang tối → hiện mặt trời
        } else {
            document.documentElement.classList.remove('dark');
            themeIcon.classList.replace('fa-sun', 'fa-moon'); // Đang sáng → hiện mặt trăng
        }

        themeToggle.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');

            if (document.documentElement.classList.contains('dark')) {
                localStorage.setItem('theme', 'dark');
                themeIcon.classList.replace('fa-moon', 'fa-sun');
            } else {
                localStorage.setItem('theme', 'light');
                themeIcon.classList.replace('fa-sun', 'fa-moon');
            }
        });
        // ========================================
        // CALL VIDEO
        // ========================================
        function closeCallRejectedModal() {
            document.getElementById("callRejectedModal").classList.add("hidden");
            cleanupCall();
        }

        function closeCallEndedModal() {
            document.getElementById("callEndedModal").classList.add("hidden");
            cleanupCall();
        }
        //Other
        document.addEventListener('DOMContentLoaded', () => {
            const customSelects = document.querySelectorAll('.custom-select');

            customSelects.forEach(select => {
                const displayed = select.querySelector('.select-displayed');
                const optionsList = select.querySelector('.select-options');
                const hiddenInput = select.querySelector('input[type="hidden"]');

                // 1. Xử lý mở/đóng danh sách
                displayed.addEventListener('click', () => {
                    optionsList.classList.toggle('active');
                });

                // 2. Xử lý chọn giá trị
                optionsList.querySelectorAll('li').forEach(option => {
                    option.addEventListener('click', () => {
                        const value = option.getAttribute('data-value');

                        // Cập nhật input ẩn
                        hiddenInput.value = value;

                        // Cập nhật hiển thị (copy HTML của li)
                        displayed.innerHTML = option.innerHTML;

                        // Đóng danh sách
                        optionsList.classList.remove('active');
                    });
                });

                // Đóng khi click ra ngoài
                document.addEventListener('click', (e) => {
                    if (!select.contains(e.target)) {
                        optionsList.classList.remove('active');
                    }
                });
            });
        });
</script>


    <script>
        function toggleEmojiPicker() {
            const picker = document.getElementById("emojiPicker");
            if (picker) {
                picker.classList.toggle("hidden");
                // Đóng nếu click ra ngoài (đã có logic handle click outside cho dropdown khác, có thể reuse hoặc add new)
            }
        }

        function insertEmoji(emoji) {
            const textarea = document.querySelector("#postModal textarea[name='Content']");
            if (textarea) {
                // Insert at cursor position if possible, or just append
                const start = textarea.selectionStart;
                const end = textarea.selectionEnd;
                const text = textarea.value;
                const before = text.substring(0, start);
                const after = text.substring(end, text.length);
                textarea.value = before + emoji + after;
                textarea.selectionStart = textarea.selectionEnd = start + emoji.length;
                textarea.focus();
            }
        }
        
        // Hide emoji picker when clicking outside
        document.addEventListener('click', function(event) {
            const picker = document.getElementById("emojiPicker");
            const btn = event.target.closest('button[onclick="toggleEmojiPicker()"]');
            
            if (picker && !picker.classList.contains('hidden') && !picker.contains(event.target) && !btn) {
                picker.classList.add('hidden');
            }
        });
    </script>
