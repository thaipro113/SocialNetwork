    function getIncomingRequestButtons(s) {
        return `<div class="flex gap-2">
                    <button onclick="acceptFriendRequest(${s.requestId}, ${s.userId})" class="px-4 py-3 bg-green-500 hover:bg-green-600 text-white font-bold text-sm rounded-xl shadow-lg hover:shadow-xl transition">Chấp nhận</button>
                    <button onclick="declineFriendRequest(${s.requestId}, ${s.userId})" class="px-4 py-3 bg-gray-400 hover:bg-gray-500 text-white font-bold text-sm rounded-xl shadow-lg hover:shadow-xl transition">Từ chối</button>
                </div>`;
