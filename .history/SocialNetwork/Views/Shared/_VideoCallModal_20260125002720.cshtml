<div id="videoCallModal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl h-[90vh] flex flex-col">
        <!-- Header -->
        <div class="p-2 md:p-4 border-b bg-gray-800 text-white flex items-center justify-between gap-2">
            <div class="flex items-center gap-2 md:gap-3">
                <div id="callStatus" class="text-sm md:text-lg font-semibold">Đang gọi...</div>
            </div>
            <button onclick="endVideoCall()" class="px-2 md:px-4 py-1 md:py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition text-xs md:text-base flex-shrink-0">
                Kết thúc
            </button>
        </div>
        <!-- Video Container -->
        <div class="flex-1 relative bg-black rounded-b-2xl overflow-hidden">
            <!-- Remote Videos Container -->
            <div id="remoteVideosContainer" class="w-full h-full flex flex-wrap items-center justify-center bg-black">
                <!-- Videos will be added here dynamically -->
            </div>
            
            <!-- Local Video (bản thân) - Picture in Picture -->
            <div class="absolute bottom-4 right-4 w-40 h-32 md:w-64 md:h-48 bg-gray-900 rounded-lg overflow-hidden shadow-2xl">
                <video id="localVideo" autoplay playsinline muted class="absolute inset-0 w-full h-full object-cover" style="background: #333; z-index: 20; transform: scaleX(-1);"></video>
                <div id="localVideoPlaceholder" class="absolute inset-0 flex items-center justify-center bg-gray-800 text-white z-30">
                    <div class="text-center">
                        <div class="text-2xl md:text-4xl mb-2"><i class="fa-solid fa-camera"></i></div>
                        <div class="text-xs md:text-sm">Camera của bạn</div>
                    </div>
                </div>
            </div>
            <!-- Call Status Overlay -->
            <div id="callStatusOverlay" class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-50">
                <div class="text-center text-white">
                    <div class="text-4xl mb-4 animate-pulse"><i class="fa-solid fa-phone"></i></div>
                    <div id="callStatusText" class="text-xl font-semibold">Đang kết nối...</div>
                </div>
            </div>
        </div>
        <!-- Controls -->
        <div class="p-2 md:p-4 bg-gray-100 flex items-center justify-center gap-2 md:gap-4 flex-wrap">
            <button id="toggleCameraBtn" onclick="toggleCamera()" class="px-3 md:px-6 py-2 md:py-3 bg-gray-600 text-white rounded-full hover:bg-gray-700 transition flex items-center gap-1 md:gap-2 text-xs md:text-base">
                <span id="cameraIcon"><i class="fa-solid fa-camera"></i></span>
                <span id="cameraText" class="hidden md:inline">Tắt camera</span>
            </button>
            <button id="toggleMicBtn" onclick="toggleMicrophone()" class="px-3 md:px-6 py-2 md:py-3 bg-gray-600 text-white rounded-full hover:bg-gray-700 transition flex items-center gap-1 md:gap-2 text-xs md:text-base">
                <span id="micIcon"><i class="fa-solid fa-microphone"></i></span>
                <span id="micText" class="hidden md:inline">Tắt mic</span>
            </button>
            <button onclick="endVideoCall()" class="px-3 md:px-6 py-2 md:py-3 bg-red-600 text-white rounded-full hover:bg-red-700 transition flex items-center gap-1 md:gap-2 text-xs md:text-base">
                <span><i class="fa-solid fa-phone"></i></span>
                <span class="hidden md:inline">Kết thúc</span>
            </button>
        </div>
    </div>
</div>

<!-- Incoming Call Modal -->
<div id="incomingCallModal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl p-4 md:p-8 text-center max-w-md w-full">
        <div class="text-4xl md:text-6xl mb-4 animate-pulse"><i class="fa-solid fa-phone"></i></div>
        <h3 class="text-lg md:text-2xl font-semibold mb-2" id="incomingCallerName">Cuộc gọi đến</h3>
        <p class="text-sm md:text-base text-gray-600 mb-6">Đang gọi video...</p>
        <div class="flex gap-2 md:gap-4 justify-center flex-wrap">
            <button onclick="acceptIncomingCall()" class="px-4 md:px-6 py-2 md:py-3 bg-green-600 text-white rounded-full hover:bg-green-700 transition text-sm md:text-base">
                Chấp nhận
            </button>
            <button onclick="rejectIncomingCall()" class="px-4 md:px-6 py-2 md:py-3 bg-red-600 text-white rounded-full hover:bg-red-700 transition text-sm md:text-base">
                Từ chối
            </button>
        </div>
    </div>
</div>
