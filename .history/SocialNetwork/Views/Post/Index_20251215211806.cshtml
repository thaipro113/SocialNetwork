@section Scripts {
    <script>
        // ==============================
        // Constants/State
        // ==============================
        let currentCommentId = null;
        let currentPostId = null;
        let deleteActionType = null; // 'post' or 'comment'
        let postReturnUrl = null;

        const modal = document.getElementById("confirmationModal");
        const confirmDeleteBtn = document.getElementById("confirmDelete");
        const cancelDeleteBtn = document.getElementById("cancelDelete");
        const modalMessageEl = document.getElementById("modal-delete-message");

        // Share Modal elements
        const shareModal = document.getElementById("shareModal");
        const confirmShareBtn = document.getElementById("confirmShare");
        const cancelShareBtn = document.getElementById("cancelShare");
        const shareContentInput = document.getElementById("shareContent");
        let sharePostId = null;


        // ==============================
        // Toggle hiển thị Comments
        // ==============================
        function toggleComments(id) {
            const el = document.getElementById(id);
            el.classList.toggle("hidden");
        }

        // ==============================
        // Toggle menu ⋯
        // ==============================
        function toggleMenu(btn) {
            const menu = btn.nextElementSibling;
            document.querySelectorAll(".post-menu").forEach(m => {
                if (m !== menu) m.classList.add("hidden");
            });
            menu.classList.toggle("hidden");
        }

        document.addEventListener("click", function (e) {
            document.querySelectorAll(".post-menu").forEach(menu => {
                if (!menu.parentElement.contains(e.target)) {
                    menu.classList.add("hidden");
                }
            });
        });

        // ==============================
        // CSRF Token helper
        // ==============================
        function getToken() {
            const token = document.querySelector("input[name='__RequestVerificationToken']");
            return token ? token.value : "";
        }

        // ==============================
        // LIKE Post (AJAX)
        // ==============================
        document.querySelectorAll(".reaction-btn").forEach(btn => {
            btn.addEventListener("click", async function (e) {
                e.preventDefault();

                const form = this.closest("form");
                const postId = parseInt(form.querySelector("input[name='postId']").value);

                const response = await fetch("/Post/Like", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": getToken()
                    },
                    body: JSON.stringify(postId)
                });

                if (!response.ok) return;
                const data = await response.json();

                // --- Cập nhật hiển thị Like ---
                const likeWrapper = document.getElementById(`like-wrapper-${postId}`);
                const likeCountEl = document.getElementById(`like-count-${postId}`);

                if (data.likes > 0) {
                    likeWrapper.style.display = "flex";
                    likeCountEl.innerText = data.showText;
                } else {
                    likeWrapper.style.display = "none";
                    likeCountEl.innerText = "";
                }

                // cập nhật trạng thái nút
                const icon = this.querySelector("i");
                const label = this.querySelector("span:last-child");

                if (data.isLiked) {
                    icon.className = "fa-solid fa-thumbs-up";
                    label.innerText = "Đã thích";
                    this.classList.add("text-blue-600", "font-semibold");
                    this.dataset.liked = "true";
                } else {
                    icon.className = "fa-regular fa-thumbs-up";
                    label.innerText = "Thích";
                    this.classList.remove("text-blue-600", "font-semibold");
                    this.dataset.liked = "false";
                }
            });
        });

        // ==============================
        // COMMENT (AJAX)
        // ==============================


        // ==============================
        // Modal & DELETE Comment/Post
        // ==============================

        // Bắt sự kiện click vào nút XÓA BÀI VIẾT
        document.querySelectorAll(".delete-post-btn").forEach(btn => {
            btn.addEventListener("click", function (e) {
                e.preventDefault();
                currentPostId = this.dataset.postId;
                postReturnUrl = this.dataset.returnUrl;
                deleteActionType = 'post';

                // Thay đổi nội dung modal
                modalMessageEl.innerText = "Bạn có chắc muốn xóa bài viết này?";

                // Hiển thị modal
                modal.classList.add("show");
            });
        });

        // Bắt sự kiện click vào nút XÓA BÌNH LUẬN (Đã có sẵn)
        document.addEventListener("click", async function (e) {
            if (e.target.classList.contains("delete-comment-btn")) {
                currentCommentId = e.target.dataset.commentId;
                currentPostId = e.target.dataset.postId;
                deleteActionType = 'comment';

                // Thay đổi nội dung modal
                modalMessageEl.innerText = "Bạn có chắc muốn xóa bình luận này?";

                // Hiển thị modal xác nhận
                modal.classList.add("show");

                return; // Ngăn chặn hành động tiếp theo cho đến khi người dùng xác nhận
            }
        });

        // Xử lý khi nhấn nút XÁC NHẬN (trong modal)
        confirmDeleteBtn.addEventListener("click", async function () {
            modal.classList.remove("show");

            if (deleteActionType === 'comment' && currentCommentId && currentPostId) {
                try {
                    const res = await fetch("@Url.Action("DeleteComment", "Post")", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "RequestVerificationToken": getToken()
                        },
                        body: JSON.stringify(parseInt(currentCommentId))
                    });
                    const data = await res.json();

                    if (data.success) {
                        // Xóa khỏi DOM
                        const el = document.getElementById(`comment-${currentCommentId}`);
                        if (el) el.remove();

                        // Update số comment
                        const commentCountEl = document.getElementById(`comment-count-${currentPostId}`);
                        if (commentCountEl) {
                            if (data.comments === 0) {
                                commentCountEl.classList.add("hidden");
                            } else {
                                commentCountEl.classList.remove("hidden");
                                commentCountEl.innerHTML = `<a onclick="toggleComments('comment-section-${currentPostId}')">${data.comments} bình luận</a>`;
                            }
                        }
                    }
                } catch (err) {
                    console.error("Delete comment error:", err);
                }
            } else if (deleteActionType === 'post' && currentPostId) {
                // Xử lý xóa bài viết
                try {
                    const res = await fetch("/Post/Delete", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded",
                            "RequestVerificationToken": getToken()
                        },
                        body: `postId=${currentPostId}&returnUrl=${encodeURIComponent(postReturnUrl)}`
                    });

                    // Nếu thành công (ví dụ: nhận response status 200 hoặc redirect)
                    if (res.ok || res.redirected) {
                        // Xóa bài viết khỏi DOM
                        const postEl = document.querySelector(`[data-post-id="${currentPostId}"]`).closest('article');
                        if (postEl) {
                            postEl.remove();
                        }

                        // Hoặc chuyển hướng nếu cần thiết
                        if (res.redirected) {
                            window.location.href = res.url;
                        }
                    } else {
                        console.error("Delete post failed");
                        // Hiển thị thông báo lỗi nếu cần
                    }

                } catch (err) {
                    console.error("Delete post error:", err);
                }
            }

            // Reset state
            currentCommentId = null;
            currentPostId = null;
            deleteActionType = null;
            postReturnUrl = null;
        });

        // Xử lý khi nhấn nút HỦY (trong modal)
        cancelDeleteBtn.addEventListener("click", function () {
            modal.classList.remove("show");
            // Reset state
            currentCommentId = null;
            currentPostId = null;
            deleteActionType = null;
            postReturnUrl = null;
        });


        // ==============================
        // SHARE FUNCTIONALITY
        // ==============================
        document.querySelectorAll(".share-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                sharePostId = this.dataset.postId;
                shareContentInput.value = ""; // Clear previous content
                shareModal.classList.remove("hidden");
            });
        });

        cancelShareBtn.addEventListener("click", function () {
            shareModal.classList.add("hidden");
            sharePostId = null;
        });

        confirmShareBtn.addEventListener("click", async function () {
            if (!sharePostId) return;

            const content = shareContentInput.value;
            try {
                const res = await fetch("/Post/Share", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded",
                    },
                    body: `postId=${sharePostId}&content=${encodeURIComponent(content)}`
                });

                const data = await res.json();
                if (data.success) {
                    shareModal.classList.add("hidden");
                    location.reload(); // Reload to show new post
                } else {
                    alert("Có lỗi xảy ra khi chia sẻ.");
                }
            } catch (err) {
                console.error("Share error:", err);
                alert("Lỗi kết nối.");
            }
        });


        // ==============================
        // STORY FUNCTIONALITY
        // ==============================
        let storiesData = [];
        let currentStoryUserIndex = 0;
        let currentStoryIndex = 0;
        let storyTimer = null;
        const STORY_DURATION = 5000; // 5 seconds

        let currentStoryFile = null;

        function uploadStory(input) {
            if (input.files && input.files[0]) {
                currentStoryFile = input.files[0];
                const file = currentStoryFile;
                const modal = document.getElementById("createStoryModal");
                const img = document.getElementById("createPreviewImg");
                const video = document.getElementById("createPreviewVideo");
                
                img.classList.add("hidden");
                video.classList.add("hidden");
                
                const url = URL.createObjectURL(file);
                
                if (file.type.startsWith("video")) {
                    video.src = url;
                    video.classList.remove("hidden");
                } else {
                    img.src = url;
                    img.classList.remove("hidden");
                }
                
                modal.classList.remove("hidden");
            }
            input.value = ""; // Reset input
        }

        function closeCreateStoryModal() {
             document.getElementById("createStoryModal").classList.add("hidden");
             const v = document.getElementById("createPreviewVideo");
             v.pause();
             v.src = "";
             document.getElementById("storyCaptionInput").value = "";
             currentStoryFile = null;
        }

        async function postStory() {
            if (!currentStoryFile) return;
            const caption = document.getElementById("storyCaptionInput").value;
            
            const formData = new FormData();
            formData.append("media", currentStoryFile);
            formData.append("content", caption);

            try {
                const res = await fetch("/Story/Create", {
                    method: "POST",
                    body: formData
                });
                if (res.ok) {
                    // alert("Đã đăng tin thành công!"); // Optional alert
                    loadStories();
                    closeCreateStoryModal();
                } else {
                    alert("Lỗi khi đăng tin.");
                }
            } catch (err) {
                console.error("Upload story error", err);
            }
        }

        async function loadStories() {
            try {
                const res = await fetch("/Story/GetFriendStories");
                const data = await res.json();
                if (data.success) {
                    storiesData = data.data;
                    renderStoryBar();
                }
            } catch (err) {
                console.error("Load stories error", err);
            }
        }

        function renderStoryBar() {
            const container = document.getElementById("story-bar");
            // Keep the first item (Create Story)
            const createCard = container.firstElementChild;
            container.innerHTML = "";
            container.appendChild(createCard);

            storiesData.forEach((userStories, index) => {
                const latestStory = userStories.stories[0]; // Show latest
                const borderColor = userStories.allSeen ? 'border-gray-500' : 'border-blue-500';
                
                const html = `
                    <div class="flex-shrink-0 w-32 h-48 relative rounded-xl overflow-hidden cursor-pointer group shadow-sm hover:shadow-md transition-all border-2 ${borderColor} p-[2px]" onclick="openStoryViewer(${index})">
                        <div class="w-full h-full rounded-lg overflow-hidden relative">
                             ${latestStory.type === 'Video' 
                                ? `<video src="${latestStory.url}" class="w-full h-full object-cover"></video>` 
                                : `<img src="${latestStory.url}" class="w-full h-full object-cover transition duration-300 group-hover:scale-110">`
                             }
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                            <div class="absolute top-2 left-2 w-8 h-8 rounded-full border-2 ${borderColor} overflow-hidden bg-white">
                                <img src="/uploads/${userStories.avatar}" class="w-full h-full object-cover">
                            </div>
                            <div class="absolute bottom-2 left-2 right-2 text-white text-xs font-semibold truncate drop-shadow-md">${userStories.username}</div>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        function openStoryViewer(userIndex) {
            currentStoryUserIndex = userIndex;
            currentStoryIndex = 0;
            document.getElementById("storyViewerModal").classList.remove("hidden");
            showStory();
        }

        function closeStoryViewer() {
            document.getElementById("storyViewerModal").classList.add("hidden");
            clearTimeout(storyTimer);
             const video = document.getElementById("storyVideo");
            video.pause();
            video.src = "";
            renderStoryBar(); // Refresh states (seen colors)
        }



        // --- PAUSE / RESUME ---
        let isPaused = false;
        let remainingTime = STORY_DURATION;
        let pauseStartTime = 0;

        function toggleStoryPlayback() {
            if (isPaused) {
                resumeStory();
            } else {
                pauseStory();
            }
        }

        function updatePlayPauseIcon() {
            const btn = document.getElementById("playPauseBtn");
            if (isPaused) {
                btn.innerHTML = '<i class="fa-solid fa-play"></i>';
            } else {
                btn.innerHTML = '<i class="fa-solid fa-pause"></i>';
            }
        }

        function pauseStory() {
            if (isPaused) return; // Already paused
            isPaused = true;
            updatePlayPauseIcon();
            clearTimeout(storyTimer);
            
            // Calculate remaining time
            const elapsed = Date.now() - storyStartTime;
            if (remainingTime > elapsed) {
                remainingTime -= elapsed;
            } else {
                remainingTime = 0;
            }
            
            // Pause video
            const video = document.getElementById("storyVideo");
            if (!video.classList.contains("hidden")) {
                video.pause();
            }

            // Pause progress bar
            const activeBar = document.querySelector("#storyProgressContainer > div > div[style*='width: 100%'][style*='transition']");
            if (activeBar) {
                const computedWidth = window.getComputedStyle(activeBar).width;
                activeBar.style.transition = 'none';
                activeBar.style.width = computedWidth;
            }
        }

        function resumeStory() {
            if (!isPaused) return;
            isPaused = false;
            updatePlayPauseIcon();
            
            storyStartTime = Date.now(); 

            // Resume timer
             const video = document.getElementById("storyVideo");
            if (!video.classList.contains("hidden")) {
                video.play();
            } else {
                 storyTimer = setTimeout(nextStory, remainingTime); 
            }

            // Resume progress bar
            const allBars = document.querySelectorAll("#storyProgressContainer > div > div");
            if (allBars[currentStoryIndex]) {
                 const activeBar = allBars[currentStoryIndex];
                 
                 activeBar.style.transition = `width ${remainingTime}ms linear`;
                 
                 // Small delay to ensure transition property applies before width change
                 setTimeout(() => {
                    activeBar.style.width = "100%";
                 }, 10);
            }
        }

        function nextStory() {
            const userStories = storiesData[currentStoryUserIndex];
            if (currentStoryIndex < userStories.stories.length - 1) {
                currentStoryIndex++;
                showStory();
            } else {
                // Next user
                if (currentStoryUserIndex < storiesData.length - 1) {
                    currentStoryUserIndex++;
                    currentStoryIndex = 0;
                    showStory();
                } else {
                    closeStoryViewer();
                }
            }
        }

        function prevStory() {
            if (currentStoryIndex > 0) {
                currentStoryIndex--;
                showStory();
            } else {
                // Prev user
                if (currentStoryUserIndex > 0) {
                    currentStoryUserIndex--;
                    currentStoryIndex = storiesData[currentStoryUserIndex].stories.length - 1;
                    showStory();
                }
            }
        }

        // --- DELETE ---
        function deleteCurrentStory() {
             document.getElementById("deleteStoryModal").classList.remove("hidden");
             isPaused = true;
             updatePlayPauseIcon();
             const video = document.getElementById("storyVideo");
             if (!video.paused) video.pause();
             clearTimeout(storyTimer);
        }

        async function confirmDeleteStory() {
            document.getElementById("deleteStoryModal").classList.add("hidden");
            
            const userStories = storiesData[currentStoryUserIndex];
            const story = userStories.stories[currentStoryIndex];
            
            try {
                const res = await fetch("/Story/Delete", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(story.id)
                });
                if (res.ok) {
                    // Remove from local data
                    userStories.stories.splice(currentStoryIndex, 1);
                    if (userStories.stories.length === 0) {
                        loadStories(); // Reload all if user has no stories left
                        closeStoryViewer();
                    } else {
                        // Show next story or close if last
                         if (currentStoryIndex >= userStories.stories.length) {
                             currentStoryIndex = 0; 
                         }
                         showStory();
                    }
                } else {
                    alert("Lỗi khi xóa tin.");
                }
            } catch (e) {
                console.error(e);
            }
        }

        async function openViewersList() {
            const userStories = storiesData[currentStoryUserIndex];
            const story = userStories.stories[currentStoryIndex];
            
            // Only owner can see
            // Force string comparison to be safe
            if (String(userStories.userId) !== String(@(currentUserId ?? 0))) {
                console.log("Not owner", userStories.userId, @(currentUserId ?? 0));
                return;
            }

            // Pause story
            isPaused = true;
            updatePlayPauseIcon();
            const video = document.getElementById("storyVideo");
            if(!video.paused) video.pause();
            clearTimeout(storyTimer);

            const modal = document.getElementById("viewersListModal");
            const content = document.getElementById("viewersListContent");
            content.innerHTML = '<div class="text-center p-4 text-gray-500">Đang tải...</div>';
            modal.classList.remove("hidden");

            try {
                const res = await fetch(`/Story/GetStoryViewers/${story.id}`);
                const data = await res.json();
                
                if (data.success) {
                    if (data.data.length === 0) {
                        content.innerHTML = '<div class="text-center p-4 text-gray-500 dark:text-gray-400">Chưa có ai xem tin này.</div>';
                    } else {
                        content.innerHTML = data.data.map(v => `
                            <div class="flex items-center p-2 mb-2 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition border-b dark:border-gray-700 last:border-0">
                                <img src="/uploads/${v.avatar}" class="w-10 h-10 rounded-full object-cover border border-gray-200">
                                <div class="ml-3 flex-1">
                                    <div class="font-semibold text-sm dark:text-white">${v.username}</div>
                                    <div class="text-xs text-gray-500 dark:text-gray-400">${timeAgo(v.viewedAt)}</div>
                                </div>
                            </div>
                        `).join("");
                    }
                } else {
                    content.innerHTML = '<div class="text-center p-4 text-red-500">Lỗi tải danh sách.</div>';
                }
            } catch (err) {
                 console.error(err);
                 content.innerHTML = '<div class="text-center p-4 text-red-500">Lỗi kết nối.</div>';
            }
        }

        function showStory() {
            clearTimeout(storyTimer);
            isPaused = false;
            updatePlayPauseIcon();
            remainingTime = STORY_DURATION;
            storyStartTime = Date.now();

            const userStories = storiesData[currentStoryUserIndex];
            const story = userStories.stories[currentStoryIndex];

            // Mark as seen if not yet
            // Only mark if NOT owner
            // Safe comparison
            const isOwner = String(userStories.userId) === String(@(currentUserId ?? 0));
            
            if (!story.isSeen && !isOwner) {
                // Call API
                fetch('/Story/MarkAsSeen', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(story.id)
                }); // Fire and forget

                // Update local state
                story.isSeen = true;
                story.viewCount = (story.viewCount || 0) + 1;

                // Check if all seen for this user
                const allNowSeen = userStories.stories.every(s => s.isSeen);
                if (allNowSeen) {
                    userStories.allSeen = true;
                }
            }

            // Update View Count UI
            const viewCountEl = document.getElementById("viewCountValue");
            if (viewCountEl) viewCountEl.innerText = story.viewCount || 0;

            // Check ownership for delete button
            const deleteBtn = document.getElementById("deleteStoryBtn");
            if (userStories.userId === @(currentUserId ?? 0)) {
                deleteBtn.classList.remove("hidden");
            } else {
                deleteBtn.classList.add("hidden");
            }

            // Navigation Buttons Visibility
            const prevBtn = document.getElementById("prevStoryBtn");
            const nextBtn = document.getElementById("nextStoryBtn");

            // Prev Button
            if (currentStoryUserIndex === 0 && currentStoryIndex === 0) {
                prevBtn.classList.add("hidden");
            } else {
                prevBtn.classList.remove("hidden");
            }

            // Next Button
            const isLastUser = currentStoryUserIndex === storiesData.length - 1;
            const isLastStory = currentStoryIndex === userStories.stories.length - 1;
            if (isLastUser && isLastStory) {
                nextBtn.classList.add("hidden");
            } else {
                nextBtn.classList.remove("hidden");
            }

            // Update Header
            document.getElementById("viewerAvatar").src = `/uploads/${userStories.avatar}`;
            document.getElementById("viewerName").textContent = userStories.username;
            document.getElementById("viewerTime").textContent = timeAgo(story.createdAt);

            // Update progress bars
            const progressContainer = document.getElementById("storyProgressContainer");
            progressContainer.innerHTML = "";
            const values = []; // Store references
            userStories.stories.forEach((_, idx) => {
                const bar = document.createElement("div");
                bar.className = "flex-1 h-full bg-gray-600 rounded-full overflow-hidden";
                const inner = document.createElement("div");
                inner.className = "h-full bg-white transition-all duration-linear";
                
                if (idx < currentStoryIndex) {
                    inner.style.width = "100%";
                } else {
                    inner.style.width = "0%";
                }
                values.push(inner);
                bar.appendChild(inner);
                progressContainer.appendChild(bar);
            });

            // Show Media
            const img = document.getElementById("storyImage");
            const video = document.getElementById("storyVideo");
            const storyContent = document.getElementById("storyContent");

            storyContent.textContent = story.content || "";

            if (story.type === 'Video') {
                img.classList.add("hidden");
                video.classList.remove("hidden");
                
                video.onloadedmetadata = function() {
                    const durationMs = video.duration * 1000;
                    remainingTime = durationMs;
                    
                    // Update active progress bar duration
                    const activeBar = values[currentStoryIndex];
                     if (activeBar) {
                        activeBar.style.transition = 'none';
                        activeBar.style.width = '0%';
                        
                        // Force reflow
                        void activeBar.offsetWidth;
                        
                        setTimeout(() => {
                            activeBar.style.transition = `width ${durationMs}ms linear`;
                            activeBar.style.width = "100%";
                        }, 50);
                    }
                };

                video.src = story.url;
                video.play();
                
                // Video ends -> Next
                video.onended = nextStory;
            } else {
                video.classList.add("hidden");
                video.pause();
                img.classList.remove("hidden");
                img.src = story.url;
                remainingTime = STORY_DURATION;

                 // Ensure progress bar animation for image
                 const activeBar = values[currentStoryIndex];
                 if (activeBar) {
                    setTimeout(() => {
                         activeBar.style.transition = `width ${STORY_DURATION}ms linear`;
                         activeBar.style.width = "100%";
                    }, 50);
                 }

                // Auto advance
                storyTimer = setTimeout(nextStory, STORY_DURATION);
            }
        }

        // Init
        if (document.getElementById("story-bar")) {
            loadStories();
        }


        // ==============================
        // Hiển thị "time ago"
        // ==============================
        function timeAgo(date) {
            const now = new Date();
            const past = new Date(date);
            const diff = Math.floor((now - past) / 1000);

            if (diff < 60) return `Vừa xong`;
            if (diff < 3600) return `${Math.floor(diff / 60)} phút trước`;
            if (diff < 86400) return `${Math.floor(diff / 3600)} giờ trước`;
            if (diff < 2592000) return `${Math.floor(diff / 86400)} ngày trước`;
            return past.toLocaleDateString("vi-VN");
        }

        document.querySelectorAll(".time-ago").forEach(el => {
            el.textContent = timeAgo(el.dataset.time);
        });
    </script>
}