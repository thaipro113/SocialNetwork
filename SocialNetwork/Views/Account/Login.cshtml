@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/Temp.cshtml";
}
<div class="w-full max-w-md mx-auto" style="padding:20px 0px;">
        <div class="glass-effect rounded-3xl p-8 bg-white shadow-sm card-hover">
            <h3 class="text-2xl font-bold text-gray-900 mb-6 text-center">Đăng nhập</h3>
            @if (ViewBag.Error != null)
            {
                <div class="mb-6 text-red-600 text-center font-medium">@ViewBag.Error</div>
            }
            <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6">
                <!-- ✅ Thêm input ẩn để giữ returnUrl -->
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2" for="username">Username</label>
                    <input type="text" name="username" id="username"
                           class="w-full px-4 py-3 bg-gray-100 text-gray-900 placeholder-gray-500 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 input-glow"
                           placeholder="Nhập username của bạn" required>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2" for="password">Mật khẩu</label>
                    <div class="relative">
                        <input type="password" name="password" id="loginPassword"
                               class="w-full px-4 py-3 bg-gray-100 text-gray-900 placeholder-gray-500 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 input-glow"
                               placeholder="Nhập mật khẩu" required>
                        <button type="button" onclick="togglePassword('loginPassword')"
                                class="absolute right-3 top-3.5 text-gray-500 hover:text-gray-700 transition-colors">
                        <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <a href="#" class="text-sm text-purple-600 hover:text-purple-500 transition-colors">Quên mật khẩu?</a>
                </div>

                <button type="submit"
                        class="w-full gradient-bg text-white py-3 px-6 rounded-xl font-semibold btn-hover">
                    Đăng nhập 
                </button>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm text-gray-600">
                    Chưa có tài khoản? <a href="@Url.Action("Register", "Account")" class="text-purple-600 hover:text-purple-500 transition-colors">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const button = input.nextElementSibling;
            if (input.type === 'password') {
                input.type = 'text';
                button.innerHTML = '<i class="fa-solid fa-eye-slash"></i>';
            } else {
                input.type = 'password';
                button.innerHTML = '<i class="fa-solid fa-eye"></i>';
            }
        }

        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('focus', function () {
                this.parentElement.classList.add('transform', 'scale-105');
            });
            input.addEventListener('blur', function () {
                this.parentElement.classList.remove('transform', 'scale-105');
            });
        });

        document.querySelectorAll('button[type="submit"]').forEach(button => {
            button.addEventListener('click', function (e) {
                const ripple = document.createElement('span');
                const rect = this.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);
                const x = e.clientX - rect.left - size / 2;
                const y = e.clientY - rect.top - size / 2;
                ripple.style.width = ripple.style.height = size + 'px';
                ripple.style.left = x + 'px';
                ripple.style.top = y + 'px';
                ripple.classList.add('ripple');
                this.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });
    </script>
    <style>
       
        .glass-effect {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .input-glow {
            transition: all 0.3s ease;
        }
        .input-glow:focus {
            box-shadow: 0 0 20px rgba(102, 126, 234, 0.4);
            transform: translateY(-2px);
        }
        .btn-hover {
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .btn-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }
     
      
    </style>
}