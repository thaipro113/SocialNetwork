@{
    ViewData["Title"] = "Bạn bè";
    Layout = "~/Views/Shared/Temp.cshtml";
    var incoming = ViewBag.Incoming as List<SocialNetwork.Models.FriendRequest>;
    var outgoing = ViewBag.Outgoing as List<SocialNetwork.Models.FriendRequest>;
    var friends = ViewBag.Friends as List<SocialNetwork.Models.User>;
}

<div class="max-w-6xl mx-auto mt-8 px-4">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- CỘT BÊN TRÁI: DANH SÁCH BẠN BÈ -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="p-5 border-b border-gray-200 dark:border-gray-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white">Bạn bè (@friends.Count)</h3>
                <!-- THANH TÌM KIẾM BẠN BÈ -->
                <div class="relative">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                    <input type="text"
                           id="friendSearchInput"
                           placeholder="Tìm kiếm bạn bè..."
                           class="w-full pl-11 pr-4 py-3 bg-gray-100 dark:bg-gray-700/70 border border-gray-300 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all text-sm placeholder-gray-500 dark:placeholder-gray-400">
                </div>
            </div>
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
                @if (friends.Any())
                {
                    foreach (var f in friends)
                    {
                        <div class="p-5 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-all duration-200">
                            <div class="flex items-center gap-4">
                                <!-- Avatar -->
                                <a href="@Url.Action("Profile","User", new { id = f.UserId })" class="flex-shrink-0">
                                    <img src="@(string.IsNullOrEmpty(f.ImageUrl) ? Url.Content("~/Uploads/default-avatar.png") : Url.Content($"~/Uploads/{f.ImageUrl}"))"
                                         class="w-12 h-12 rounded-full object-cover ring-2 ring-gray-200 dark:ring-gray-600" />
                                </a>

                                <!-- Tên + 2 nút (dọc xuống để không bị đè) -->
                                <div class="flex-1 min-w-0 flex items-center justify-between">
                                    <div class="min-w-0">
                                        <a href="@Url.Action("Profile","User", new { id = f.UserId })"
                                           class="block font-semibold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition truncate text-base">
                                            @f.FullName
                                        </a>
                                    </div>

                                    <!-- 2 nút nhỏ gọn, nằm cùng dòng với tên -->
                                    <div class="flex items-center gap-2 ml-4 flex-shrink-0">
                                        <button onclick="startChat(@f.UserId)"
                                                class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium rounded-lg transition shadow-sm">
                                            Chat
                                        </button>
                                        <button onclick="unfriend(@f.UserId, this)"
                                                class="px-3 py-1.5 bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 text-xs font-medium rounded-lg transition">
                                            Unfriend
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-12 text-center">
                        <div class="w-20 h-20 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                            <i class="fas fa-user-friends text-3xl text-gray-400"></i>
                        </div>
                        <p class="text-gray-500 dark:text-gray-400 text-lg">Bạn chưa có bạn bè nào.</p>
                    </div>
                }
            </div>
        </div>

        <!-- CỘT BÊN PHẢI: LỜI MỜI KẾT BẠN -->
        <div class="lg:col-span-2 space-y-8">

            <!-- Lời mời đến bạn -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
                <div class="p-5 border-b border-gray-200 dark:border-gray-700">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Lời mời kết bạn (@incoming.Count)</h3>
                </div>
                <div class="divide-y divide-gray-200 dark:divide-gray-700">
                    @if (incoming.Any())
                    {
                        foreach (var r in incoming)
                        {
                            <div class="p-5 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-all duration-200">
                                <div class="flex items-center justify-between gap-4">
                                    <div class="flex items-center space-x-4 flex-1 min-w-0">
                                        <a href="@Url.Action("Profile","User", new { id = r.FromUserId })" class="flex-shrink-0">
                                            <img src="@(string.IsNullOrEmpty(r.FromUser.ImageUrl) ? Url.Content("~/Uploads/default-avatar.png") : Url.Content($"~/Uploads/{r.FromUser.ImageUrl}"))"
                                                 class="w-14 h-14 rounded-full object-cover ring-2 ring-gray-200 dark:ring-gray-600" />
                                        </a>
                                        <div class="min-w-0">
                                            <a href="@Url.Action("Profile","User", new { id = r.FromUserId })"
                                               class="block text-lg font-semibold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition">
                                                @r.FromUser.FullName
                                            </a>
                                            @if (!string.IsNullOrEmpty(r.Message))
                                            {
                                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-2">@r.Message</p>
                                            }
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-3 flex-shrink-0">
                                        <button onclick="respondRequest(@r.Id, true)"
                                                class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition shadow-sm">
                                            Chấp nhận
                                        </button>
                                        <button onclick="respondRequest(@r.Id, false)"
                                                class="px-5 py-2.5 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg transition">
                                            Từ chối
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-12 text-center">
                            <div class="w-20 h-20 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                                <i class="fas fa-envelope text-3xl text-gray-400"></i>
                            </div>
                            <p class="text-gray-500 dark:text-gray-400 text-lg">Không có lời mời nào.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Lời mời đã gửi -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
                <div class="p-5 border-b border-gray-200 dark:border-gray-700">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Lời mời đã gửi (@outgoing.Count)</h3>
                </div>
                <div class="divide-y divide-gray-200 dark:divide-gray-700">
                    @if (outgoing.Any())
                    {
                        foreach (var r in outgoing)
                        {
                            <div class="p-5 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-all duration-200">
                                <div class="flex items-center justify-between gap-4">
                                    <div class="flex items-center space-x-4 flex-1 min-w-0">
                                        <a href="@Url.Action("Profile","User", new { id = r.ToUserId })" class="flex-shrink-0">
                                            <img src="@(string.IsNullOrEmpty(r.ToUser.ImageUrl) ? Url.Content("~/Uploads/default-avatar.png") : Url.Content($"~/Uploads/{r.ToUser.ImageUrl}"))"
                                                 class="w-14 h-14 rounded-full object-cover ring-2 ring-gray-200 dark:ring-gray-600" />
                                        </a>
                                        <div class="min-w-0">
                                            <a href="@Url.Action("Profile","User", new { id = r.ToUserId })"
                                               class="block text-lg font-semibold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition">
                                                @r.ToUser.FullName
                                            </a>
                                            <p class="text-sm text-gray-500 dark:text-gray-400">Đang chờ phản hồi...</p>
                                        </div>
                                    </div>
                                    <button onclick="cancelRequest(@r.Id)"
                                            class="px-5 py-2.5 bg-red-100 hover:bg-red-200 text-red-600 dark:bg-red-900/30 dark:hover:bg-red-900/50 dark:text-red-400 font-medium rounded-lg transition">
                                        Hủy lời mời
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-12 text-center">
                            <div class="w-20 h-20 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                                <i class="fas fa-paper-plane text-3xl text-gray-400"></i>
                            </div>
                            <p class="text-gray-500 dark:text-gray-400 text-lg">Chưa gửi lời mời nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- MODAL XÁC NHẬN HỦY KẾT BẠN -->
<div id="unfriendModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-sm w-full overflow-hidden animate-in fade-in zoom-in duration-300">
        <div class="p-6 text-center">
            <div class="w-20 h-20 mx-auto mb-4 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center">
                <i class="fa-solid fa-user-slash text-3xl text-red-600 dark:text-red-400"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                Hủy kết bạn?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                Bạn có chắc chắn muốn hủy kết bạn với <span id="unfriendName" class="font-semibold"></span>?<br>
                Người này sẽ không còn thấy bài viết của bạn nữa.
            </p>
        </div>
        <div class="flex border-t border-gray-200 dark:border-gray-700">
            <button id="cancelUnfriend" class="flex-1 py-4 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                Hủy
            </button>
            <button id="confirmUnfriend" class="flex-1 py-4 text-white font-bold bg-gradient-to-r from-red-500 to-rose-600 hover:from-red-600 hover:to-rose-700 transition">
                Hủy kết bạn
            </button>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // HỦY LỜI MỜI → XÓA NGAY TRÊN GIAO DIỆN + RELOAD CHỈ 1 LẦN
        async function cancelRequest(id) {
            const res = await fetch("/Friend/Cancel", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(id)
            });
            const data = await res.json();

            if (data.success) {
                // 1. XÓA DÒNG GỖI TRÊN UI NGAY LẬP TỨC
                const row = document.querySelector(`button[onclick="cancelRequest(${id})"]`)?.closest('.flex');
                if (row) {
                    row.style.transition = "all 0.3s";
                    row.style.opacity = "0";
                    row.style.transform = "translateX(-20px)";
                    setTimeout(() => row.remove(), 300);
                }

                // 2. ẨN THÔNG BÁO "Chưa gửi lời mời nào" NẾU CẦN
                setTimeout(() => {
                    const remaining = document.querySelectorAll('#outgoing-list .flex');
                    const emptyMsg = document.querySelector('#outgoing-empty');
                    if (remaining.length === 0 && emptyMsg) {
                        emptyMsg.style.display = "block";
                    }
                }, 350);

                // 3. TOAST ĐẸP
                showToast("❌ Đã hủy lời mời kết bạn");
            } else {
                alert(data.message || "Lỗi khi hủy");
            }
        }

        // CHẤP NHẬN / TỪ CHỐI → XÓA DÒNG + THÊM VÀO DANH SÁCH BẠN BÈ
        async function respondRequest(id, accept) {
            const url = accept ? "/Friend/Accept" : "/Friend/Decline";
            const res = await fetch(url, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(id) });
            const data = await res.json();

            if (data.success) {
                const row = document.querySelector(`button[onclick="respondRequest(${id}, ${accept})"]`)?.closest('.flex');
                if (row) {
                    row.style.transition = "all 0.4s";
                    row.style.opacity = "0";
                    row.style.transform = "scale(0.95)";
                    setTimeout(() => row.remove(), 400);
                }

                if (accept) {
                    showToast("✅ Đã chấp nhận kết bạn!");
                    setTimeout(() => location.reload(), 800); // Reload để load danh sách bạn bè mới
                } else {
                    showToast("✅ Đã từ chối lời mời");
                }
            }
        }

        // NHẮN TIN
        function startChat(otherId) {
            fetch("/Chat/StartConversation", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(otherId)
            })
            .then(r => r.json())
            .then(d => {
                if (d.success) location.href = `/Chat/Index?c=${d.conversationId}`;
                else alert(d.message || "Lỗi");
            });
        }

        // TOAST SIÊU ĐẸP (dùng chung với Layout)
        function showToast(msg) {
            if (typeof window.showToast === 'function') {
                window.showToast(msg);
                return;
            }
            const t = document.createElement("div");
            t.className = "fixed bottom-6 right-6 bg-gradient-to-r from-red-500 to-pink-600 text-white px-6 py-4 rounded-xl shadow-2xl z-50 flex items-center gap-3 transform transition-all duration-500 translate-y-10 opacity-0";
            t.innerHTML = `<span class="text-2xl">✨</span> <div>${msg}</div>`;
            document.body.appendChild(t);
            setTimeout(() => t.classList.remove("translate-y-10", "opacity-0"), 100);
            setTimeout(() => {
                t.classList.add("translate-y-10", "opacity-0");
                setTimeout(() => t.remove(), 500);
            }, 2500);
        }

        // ĐÁNH DẤU ID CHO DỄ XÓA
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll('[onclick^="cancelRequest"]').forEach(btn => {
                const div = btn.closest('.flex');
                if (div) div.id = 'outgoing-' + btn.getAttribute('onclick').match(/\d+/)[0];
            });
        });
        let unfriendUserId = null;
        let unfriendButton = null;

        // MỞ MODAL + HIỂN THỊ TÊN NGƯỜI DÙNG
        async function unfriend(friendId, button) {
            unfriendUserId = friendId;
            unfriendButton = button;

            // Lấy tên người dùng từ dòng hiện tại
            const nameElement = button.closest('.p-5').querySelector('a.font-semibold');
            const userName = nameElement ? nameElement.textContent.trim() : "người này";

            document.getElementById("unfriendName").textContent = userName;
            document.getElementById("unfriendModal").classList.remove("hidden");
        }

        // ĐÓNG MODAL
        document.getElementById("cancelUnfriend").addEventListener("click", () => {
            document.getElementById("unfriendModal").classList.add("hidden");
            unfriendUserId = null;
            unfriendButton = null;
        });

        // XÁC NHẬN HỦY KẾT BẠN
        document.getElementById("confirmUnfriend").addEventListener("click", async () => {
            if (!unfriendUserId || !unfriendButton) return;

            const res = await fetch("/Friend/Unfriend", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector("input[name='__RequestVerificationToken']")?.value || ""
                },
                body: JSON.stringify(unfriendUserId)
            });

            const data = await res.json();

            if (data.success) {
                // Đóng modal
                document.getElementById("unfriendModal").classList.add("hidden");

                // Hiệu ứng xóa dòng mượt mà
                const row = unfriendButton.closest('.p-5');
                row.style.transition = "all 0.4s ease-out";
                row.style.opacity = "0";
                row.style.transform = "translateX(-50px)";
                setTimeout(() => row.remove(), 400);

                // Cập nhật số lượng bạn bè
                const friendCountEl = document.querySelector('h3.text-xl');
                const currentCount = parseInt(friendCountEl.textContent.match(/\d+/)?.[0] || 0);
                friendCountEl.innerHTML = `Bạn bè (${currentCount - 1})`;

                // Hiển thị toast
                showToast("Đã hủy kết bạn với " + document.getElementById("unfriendName").textContent);

                // Nếu hết bạn bè → hiện thông báo
                setTimeout(() => {
                    const remaining = document.querySelectorAll('[onclick^="startChat("]');
                    if (remaining.length === 0) {
                        const container = document.querySelector('.divide-y');
                        container.innerHTML = `
                                    <div class="p-12 text-center">
                                        <div class="w-20 h-20 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                                            <i class="fas fa-user-friends text-3xl text-gray-400"></i>
                                        </div>
                                        <p class="text-gray-500 dark:text-gray-400 text-lg">Bạn chưa có bạn bè nào.</p>
                                    </div>`;
                    }
                }, 500);
            } else {
                alert(data.message || "Không thể hủy kết bạn");
            }

            // Reset
            unfriendUserId = null;
            unfriendButton = null;
        });

        // Đóng modal khi click ngoài
        document.getElementById("unfriendModal").addEventListener("click", function (e) {
            if (e.target === this) {
                this.classList.add("hidden");
            }
        });
        // TÌM KIẾM BẠN BÈ REALTIME
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("friendSearchInput");
            if (!searchInput) return;

            // CHỈ lấy đúng các item trong cột bạn bè (cột đầu tiên, lg:col-span-1)
            const friendContainer = document.querySelector('.grid-cols-1.lg\\:grid-cols-3 > div:first-child');
            const friendItems = friendContainer?.querySelectorAll('.divide-y > div.p-5') || [];

            const titleElement = document.querySelector('.grid-cols-1.lg\\:grid-cols-3 > div:first-child h3');

            searchInput.addEventListener("input", function () {
                const query = this.value.trim().toLowerCase()
                    .normalize("NFD").replace(/[\u0300-\u036f]/g, "");

                let visibleCount = 0;
                const totalFriends = @friends.Count;

                friendItems.forEach(item => {
                    const nameEl = item.querySelector('a.font-semibold');
                    if (!nameEl) {
                        item.style.display = "none"; // ẩn phần "chưa có bạn bè" nếu có
                        return;
                    }

                    const name = nameEl.textContent.toLowerCase()
                        .normalize("NFD").replace(/[\u0300-\u036f]/g, "");

                    if (query === "" || name.includes(query)) {
                        item.style.display = "";
                        visibleCount++;
                    } else {
                        item.style.display = "none";
                    }
                });

                // Cập nhật tiêu đề
                if (titleElement) {
                    titleElement.innerHTML = query === ""
                        ? `Bạn bè (${totalFriends})`
                        : `Bạn bè (${visibleCount}/${totalFriends})`;
                }

                // Hiện thông báo không tìm thấy (chỉ trong cột bạn bè)
                const listContainer = friendContainer?.querySelector('.divide-y');
                let noResult = listContainer?.querySelector('.no-result-msg');

                if (visibleCount === 0 && query !== "") {
                    if (!noResult) {
                        noResult = document.createElement("div");
                        noResult.className = "no-result-msg p-12 text-center text-gray-500 dark:text-gray-400";
                        noResult.innerHTML = `
                                <i class="fa-solid fa-search text-5xl mb-4 opacity-30"></i>
                                <p class="text-lg font-medium">Không tìm thấy bạn bè nào</p>
                                <p class="text-sm">Thử tìm bằng tên khác nhé!</p>
                            `;
                        listContainer?.appendChild(noResult);
                    }
                } else if (noResult) {
                    noResult.remove();
                }
            });
        });
    </script>
}

